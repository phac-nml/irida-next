{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": ["allowlist"],
      "properties": {
        "allowlist": {
          "oneOf": [
            { "type": "string", "enum": ["all"] },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
