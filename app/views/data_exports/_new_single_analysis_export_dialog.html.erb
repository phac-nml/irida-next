<%= viral_dialog(open: open, size: :large) do |dialog| %>
  <% dialog.with_header(title: t(:"data_exports.new_analysis_export_dialog.title")) %>

  <div class="font-normal text-slate-500 dark:text-slate-400">
    <div class="grid gap-4">
      <div data-controller="collapsible">
        <h2 id="<%= "accordion-collapse-heading-workflows" %>">
          <button
            type="button"
            class="
              flex w-full items-center justify-between gap-3 rounded-t-lg border border-slate-200 p-3 font-medium
              text-black hover:bg-slate-100 rtl:text-right dark:border-slate-700 dark:text-white
              dark:hover:bg-slate-800
            "
            data-collapsible-target="button"
            data-action="collapsible#toggle"
          >
            <span><%= t(".single_selection") %></span>

            <span
              data-collapsible-target="icon"
              class="<%= class_names("transition-transform duration-200 mr-2 flex-shrink-0", { "rotate-180": @selected }) %>"
            >
              <%= icon(:caret_down, size: :sm) %>
            </span>
          </button>
        </h2>

        <div
          data-collapsible-target="item"
          id="<%= "accordion-collapse-body-workflows" %>"
          class="hidden"
          role="region"
          aria-labelledby="<%= "accordion-collapse-heading-workflows" %>"
        >
          <div
            class="
              border border-t-0 border-slate-200 p-2.5 text-base leading-relaxed text-slate-500
              dark:border-slate-700 dark:text-slate-400
            "
          >
            <span><%= t(:"data_exports.new_analysis_export_dialog.description.singular") %></span>
            <span><%= t(:"data_exports.new.after_submission_description_html") %></span>
          </div>

          <div
            class="
              block max-h-[200px] w-full overflow-y-auto rounded-b-lg border border-t-0 border-slate-200 p-2.5
              dark:border-slate-700 dark:bg-slate-800
            "
          >
            <div class="font-semibold text-gray-900 dark:text-white">
              <%= t("data_exports.list_workflow_execution.id") %>
              <%= workflow_execution.id %>
            </div>

            <% unless workflow_execution.name.nil? || workflow_execution.name.empty? %>
              <div class="font-normal text-gray-500 dark:text-gray-400">
                <%= t("data_exports.list_workflow_execution.name") %>
                <%= workflow_execution.name %>
              </div>
            <% end %>

            <div class="font-normal text-gray-500 dark:text-gray-400">
              <%= t("data_exports.list_workflow_execution.run_id") %>
              <%= workflow_execution.run_id %>
            </div>

            <div class="font-normal text-gray-500 dark:text-gray-400">
              <%= t("data_exports.list_workflow_execution.workflow") %>
              <%= workflow_execution.workflow.name %>
              <%= workflow_execution.metadata["workflow_version"] %>
            </div>
          </div>
        </div>
      </div>

      <%= form_for(:data_export, url: data_exports_path, method: :post) do |form| %>
        <div class="grid gap-4">
          <%= render partial: "name_and_email", locals: { form: } %>

          <div>
            <%= form.hidden_field :export_type, value: "analysis" %>

            <input type="hidden" name="data_export[export_parameters][analysis_type]" value="<%= analysis_type %>">
            <input type="hidden" name="data_export[export_parameters][ids][]" value="<%= workflow_execution.id %>">

            <% unless namespace_id.nil? %>
              <input type="hidden" name="data_export[export_parameters][namespace_id]" value="<%= namespace_id %>">
            <% end %>
          </div>

          <div>
            <%= form.submit t(:"data_exports.new.submit_button"),
                        data: {
                          turbo_frame: "_top",
                        },
                        class: "button button-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
