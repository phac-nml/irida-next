<%= turbo_stream.append "flashes" do %>
  <%= viral_flash(type:, data: message) %>
<% end %>

<% @group_links.each do |group_group_link| %>
  <%# overwrite group_group_link with namespace_group_link to access namespace_group_link.errors %>
  <% group_group_link = namespace_group_link if group_group_link == namespace_group_link %>

  <%= turbo_stream.update "group-link-#{group_group_link.id}-expiration",
                    partial: "groups/group_links/expiration",
                    locals: {
                      namespace: @namespace,
                      namespace_group_link: group_group_link,
                    } %>
<% end %>
