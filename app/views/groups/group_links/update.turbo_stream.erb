<%= turbo_stream.update "member-update-alert",
                    viral_alert(type:, message:, classes: "mb-4") %>

<% @group_links.each do |group_group_link| %>
  <%= turbo_stream.update "group-link-#{group_group_link.id}-expiration",
                    partial: "groups/group_links/expiration",
                    locals: {
                      namespace: @namespace,
                      namespace_group_link: group_group_link,
                      error: group_group_link == namespace_group_link && namespace_group_link.errors.include?(:expires_at) ? namespace_group_link.errors[:expires_at] : nil
                    } %>
<% end %>
