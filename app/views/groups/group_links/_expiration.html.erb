<% invalid_expires_at = namespace_group_link.errors.include?(:expires_at) %>

<div class="form-field <%= 'invalid' if invalid_expires_at %>">
  <%= form_with( model: namespace_group_link, url: group_group_link_path(namespace, namespace_group_link), method: :patch) do |form| %>
    <%= combobox_datepicker(
                    id: "invited-group-#{namespace_group_link.group.id}-expiration",
                    input_name: "namespace_group_link[expires_at]",
                    selected_date: namespace_group_link.expires_at,
                    autosubmit: true,
                    input_aria_label: t("groups.group_links.index.aria_labels.expires_at"),
                  ) %>
  <% end %>
</div>
