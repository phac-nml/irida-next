<% unless @member.errors.any? %>
  <%= turbo_stream.append "flashes" do %>
    <%= viral_flash(type:, data: message) %>
  <% end %>
  <turbo-stream action="refresh"></turbo-stream>
<% end %>

<%= turbo_stream.update "edit_dialog",
                      partial: "edit_modal",
                      locals: {
                        open: @member.errors.any?,
                        member: @member,
                        namespace: @namespace
                      } %>
