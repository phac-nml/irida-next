<%= turbo_stream.update "member-update-alert",
                    viral_alert(type:, message:, classes: "mb-4") %>

<%= turbo_stream.update "member-#{member.id}-access-level",
                    partial: "groups/members/access_level",
                    locals: {
                      namespace: @namespace,
                      member:,
                      access_levels: @access_levels,
                    } %>

<% @members.each do |group_member| %>
  <%= turbo_stream.update "member-#{group_member.id}-expiration",
                    partial: "groups/members/expiration",
                    locals: {
                      namespace: @namespace,
                      member: group_member,
                      error: group_member == member && member.errors.include?(:expires_at) ? member.errors[:expires_at] : nil
                    } %>
<% end %>
