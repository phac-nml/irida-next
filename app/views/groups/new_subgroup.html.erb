<%= render Viral::PageHeaderComponent.new(
  title: t(:"groups.new_subgroup.title"),
  subtitle: t(:"groups.new_subgroup.subtitle"),
) %>

<div data-controller="slugify" class="@xl:container">
  <%= form_with(model: @new_group, url: groups_path, method: :post, data:
  if Flipper.enabled?(:v2_prefixed_select2, Current.user)
    { controller: "select2--v2" }
  else
    { controller: "select2--v1" }
  end, html: { novalidate: true }) do |form| %>
    <div class="grid gap-4">
      <%= render partial: "form_fields",
      locals: {
        form: form,
        group: @new_group,
        authorized_namespaces: @authorized_namespaces,
      } %>

      <div class="flex gap-2">
        <%= render "shared/pathogen/secondary_button", href: group_path(@group) %>

        <%= form.submit t(:"groups.new_subgroup.submit"),
                      tone: :primary,
                      emphasis: :solid %>
      </div>
    </div>
  <% end %>
</div>
