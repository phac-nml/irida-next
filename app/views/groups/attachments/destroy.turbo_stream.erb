<% if destroyed_attachments %>
  <%= turbo_stream.update "attachment_modal",
                      partial: "delete_attachment_modal",
                      locals: {
                        open: false,
                        attachment: @attachment,
                        namespace: @group,
                      } %>
  <% destroyed_attachments.each do |attachment| %>
    <%= turbo_stream.append "flashes" do %>
      <%= pathogen_toast(
        type: :success,
        message: t(".success", filename: attachment.file.filename),
      ) %>
    <% end %>
  <% end %>
  <turbo-stream action="refresh"></turbo-stream>
<% else %>
  <%= turbo_stream.append "flashes" do %>
    <%= pathogen_toast(type: :error, message: message) %>
  <% end %>
<% end %>
