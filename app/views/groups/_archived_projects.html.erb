<div class="space-y-2">
  <% if @namespaces.length > 0 %>
    <%= render TreegridComponent.new(aria: {label: "Archived Projects"}) do |component| %>
      <% @namespaces.each_with_index do |namespace, namespace_index| %>
        <%= component.with_row(
          tabindex: (namespace_index.zero? ? 0 : -1),
          expandable: !@render_flat_list && namespace.children_of_type?([Namespaces::ProjectNamespace.sti_name]),
          posinset: namespace_index + 1,
          setsize: @namespaces.size,
          aria: { label: namespace_row_aria_label(namespace)},
          id: dom_id(namespace)
        ) do %>
          <%= render NamespaceRow::ContentsComponent.new(
            namespace: namespace,
            full_name: @render_flat_list,
            icon_size: :medium,
          ) %>
        <% end %>
      <% end %>
    <% end %>
    <%= render Viral::Pagy::FullComponent.new(@pagy, item: t(".pagy.item")) %>
  <% elsif @has_namespaces %>
    <%= viral_empty(
      icon_name: :magnifying_glass,
      title: t("components.viral.pagy.empty_state.title"),
      description: t("components.viral.pagy.empty_state.description"),
    ) %>
  <% else %>
    <%= viral_empty(
      title: t("groups.show.archived_projects.no_archived_projects"),
      description: t("groups.show.archived_projects.no_archived_projects_description"),
      icon_name: Group.icon,
    ) %>
  <% end %>
</div>
