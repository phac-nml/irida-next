<%= turbo_refreshes_with method: :morph, scroll: :preserve %>

<%= turbo_frame_tag "export_dialog" %>
<%= turbo_frame_tag "selected" %>

<%= render Viral::PageHeaderComponent.new(
  title: t("shared.workflow_executions.index.title"),
  subtitle: t(".subtitle"),
) do |component| %>
  <%= component.with_buttons do %>
    <% if @allowed_to[:export_data] && @has_workflow_executions %>
      <%= form_with(
            url: new_data_export_path,
            method: :get,
            id: "create-group-workflow-export-form",
            class: "hidden",
          ) do %>
        <input type="hidden" name="export_type" value="analysis">
        <input type="hidden" name="analysis_type" value="group">
        <input type="hidden" name="namespace_id" value="<%= @namespace.id %>">
      <% end %>
      <%= button_tag t("groups.workflow_executions.index.create_export_button"),
               type: "submit",
               form: "create-group-workflow-export-form",
               data: {
                 turbo_stream: true,
                 controller: "action-button",
                 action_button_required_value: 1,
               },
               class: "button button-default action-button max-sm:grow" %>
    <% end %>
  <% end %>
<% end %>

<% if @has_workflow_executions %>
  <div class="mb-4 flex flex-wrap gap-2">
    <%= form_with(
                  url: select_group_workflow_executions_url,
                  method: :get,
                  id: "select-all-form",
                  class: "hidden",
                ) do %>
      <input type="hidden" name="format" value="turbo_stream">
      <input type="hidden" name="select" value="on">
    <% end %>

    <%= button_tag t("common.controls.select_all"),
             type: "submit",
             form: "select-all-form",
             class: "button button-default max-sm:grow" %>

    <%= form_with(
                  url: select_group_workflow_executions_url,
                  method: :get,
                  id: "deselect-all-form",
                  class: "hidden",
                ) do %>
      <input type="hidden" name="format" value="turbo_stream">
    <% end %>

    <%= button_tag t("common.controls.deselect_all"),
             type: "submit",
             form: "deselect-all-form",
             class: "button button-default max-sm:grow" %>

    <div class="max-sm:hidden sm:grow" role="presentation"></div>

    <%= render partial: "workflow_executions/table_filter", locals: {
      query: @q,
      search: @query,
      url: group_workflow_executions_path,
      total_count: @pagy.count,
      page_limit: @pagy.limit,
      form_data: {
        "search-field-selection-outlet": "#workflow-executions-table",
      },
    } %>
  </div>
<% end %>

<%= render partial: "workflow_executions/table",
locals: {
  workflow_executions: @workflow_executions,
  pagy: @pagy,
  q: @q,
  has_workflow_executions: @has_workflow_executions,
  namespace: @namespace,
  empty_title: t(:"groups.workflow_executions.table.empty.title"),
  empty_description: t(:"groups.workflow_executions.table.empty.description"),
} %>
