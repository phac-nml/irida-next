<div class="text-center">
  <div class="mx-auto mb-3.5 flex h-12 w-12 items-center justify-center rounded-full bg-green-100 p-2 dark:bg-green-900">
    <%= icon(:check, size: :lg, color: :success) %>
    <span class="sr-only"><%= t(".success") %></span>
  </div>

  <p class="mb-4 text-lg font-semibold text-slate-900 dark:text-white"><%= message %></p>

  <%= viral_button(state: :primary, data: { action: 'click->viral--dialog#close' }) do %>
    <%= t(".ok_button") %>
  <% end %>
</div>

<turbo-stream action="refresh"></turbo-stream>
