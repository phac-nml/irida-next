<li
  class="w-full border-b border-slate-200 hover:bg-slate-100 dark:border-slate-600 dark:hover:bg-slate-600"
  role="none"
>
  <button
    type="submit"
    value="<%= value %>"
    name="q[metadata_template]"
    class="flex w-full cursor-pointer items-center px-3 py-2.5 text-left"
    role="menuitemradio"
    aria-checked="<%= selected %>"
    tabindex="-1"
  >
    <span class="mr-2 flex size-5 items-center justify-center" aria-hidden="true">
      <% if selected %>
        <%= icon(:check, size: :sm) %>
      <% end %>
    </span>

    <span class="flex-1">
      <%= label %>
      <%# Screen reader only indicator of selection state (visual already has icon) %>
      <% if selected %>
        <span class="sr-only"><%= t("shared.samples.metadata_templates.templates.selected") %></span>
      <% end %>
    </span>
  </button>
</li>
