<%
  i18n_line = if I18n.locale != :en
    "LocalTime.config.i18n[\"#{I18n.locale}\"] = #{t('local_time').to_json};"
  else
    ""
  end
  
  script_content = [
    'import("local-time").then(module => {',
    '  LocalTime = module.default',
    "  #{i18n_line}",
    "  LocalTime.config.locale = \"#{I18n.locale}\"",
    '  LocalTime.start()',
    '})'
  ].join("\n")
%>
<%= content_tag(:script, script_content.html_safe) %>
