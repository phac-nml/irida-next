<%# locals: (url:, form_data: nil, total_count: nil, select_form_fields: {}, deselect_form_fields: {}, select_form_id: "select-all-form", deselect_form_id: "deselect-all-form", select_button_options: {}, deselect_button_options: {}) %>

<% select_all_disabled = total_count.present? && Irida::SelectionLimits.exceeded?(total_count) %>
<% limit_alert_id = SelectionLimitableTable::SELECTION_LIMIT_ALERT_ID %>

<% select_button_options = {
     id: "select-all-button",
     name: nil,
     type: "submit",
     form: select_form_id,
     class: "button button-default max-sm:grow",
   }.merge(select_button_options) %>

<% deselect_button_options = {
     id: "deselect-all-button",
     name: nil,
     type: "submit",
     form: deselect_form_id,
     class: "button button-default max-sm:grow",
   }.merge(deselect_button_options) %>

<% if select_all_disabled %>
  <% select_button_options[:disabled] = true %>
  <% select_button_options[:aria] = (select_button_options[:aria] || {}).merge(describedby: limit_alert_id) %>
<% end %>

<%= form_with(
      url: url,
      method: :get,
      id: select_form_id,
      class: "hidden",
      data: form_data,
    ) do %>
  <% select_form_fields.each do |field_name, field_value| %>
    <%= hidden_field_tag field_name, field_value, id: nil %>
  <% end %>
<% end %>

<%= form_with(
      url: url,
      method: :get,
      id: deselect_form_id,
      class: "hidden",
  data: form_data,
    ) do %>
  <% deselect_form_fields.each do |field_name, field_value| %>
    <%= hidden_field_tag field_name, field_value, id: nil %>
  <% end %>
<% end %>

<%= button_tag t("common.controls.select_all"), **select_button_options %>

<%= button_tag t("common.controls.deselect_all"), **deselect_button_options %>
