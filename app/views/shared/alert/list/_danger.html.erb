<div
  class="
    mb-4 flex rounded-lg border border-red-500 bg-red-50 p-4 text-sm text-red-800 dark:bg-slate-800
    dark:text-red-400
  "
  role="alert"
>
  <%= icon(:info, classes: "shrink-0 inline w-5 h-5 mr-2") %>
  <span class="sr-only"><%= t("shared.alert.list.danger") %></span>

  <div>
    <span class="font-medium"><%= title %>:</span>

    <ul class="mt-1.5 ml-4 list-inside list-disc">
      <% messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
</div>
