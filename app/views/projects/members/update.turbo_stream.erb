<% unless @member.errors.any? %>
  <%= turbo_stream.update "member-update-alert",
                    viral_alert(type:, message:, classes: "mb-4") %>
<% end %>

<%= turbo_stream.update "edit_dialog",
                      partial: "edit_modal",
                      locals: {
                        open: @member.errors.any?,
                        member: @member,
                        namespace: @namespace
                      } %>
