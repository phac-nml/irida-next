<%= turbo_stream.update "member-update-alert",
                    viral_alert(type:, message:, classes: "mb-4") %>

<%= turbo_stream.update "member-#{member.id}-access-level",
                    partial: "projects/members/access_level",
                    locals: {
                      namespace: @namespace,
                      member:,
                      access_levels: @access_levels,
                    } %>

<% @members.each do |project_member| %>
  <%# overwrite project_member with member to access member.errors %>
  <% project_member = member if project_member == member %>

  <%= turbo_stream.update "member-#{project_member.id}-expiration",
                    partial: "projects/members/expiration",
                    locals: {
                      namespace: @namespace,
                      member: project_member,
                    } %>
<% end %>
