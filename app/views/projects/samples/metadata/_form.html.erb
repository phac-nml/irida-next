<div
  data-controller="projects--samples--metadata--create"
  data-projects--samples--metadata--create-key-missing-value="<%= t("projects.samples.metadata.new_metadata_modal.required_error.key") %>"
  data-projects--samples--metadata--create-value-missing-value="<%= t("projects.samples.metadata.new_metadata_modal.required_error.value") %>"
  data-projects--samples--metadata--create-form-error-value="<%= t("general.form.error_notification") %>"
>
  <div
    role="alert"
    aria-live="assertive"
    aria-atomic="true"
    data-projects--samples--metadata--create-target="formFieldError"
    class="
      alert-component mb-2 hidden border-red-300 bg-red-50 text-red-800 dark:border-red-800/50 dark:bg-red-900/20
      dark:text-red-400
    "
  >
    <div class="flex w-full items-start">
      <div class="mr-3 flex-shrink-0"><%= pathogen_icon :x_circle, color: :danger %></div>

      <div class="mt-0.5 min-w-0 flex-1">
        <div
          class="text-sm leading-5 font-medium"
          data-projects--samples--metadata--create-target="formFieldErrorMessage"
        ></div>
      </div>
    </div>
  </div>

  <%= form_with(model: @sample, url: sample_metadata_path(@sample), method: :post, data: { "projects--samples--metadata--create-target": "form" }) do |form| %>
    <div class="grid gap-2">
      <%= render partial: "shared/form/required_field_legend" %>

      <div data-projects--samples--metadata--create-target="metadataToAdd"></div>

      <template data-projects--samples--metadata--create-target="fieldTemplate">
        <div class="metadata-field-wrapper">
          <div
            class="
              inputField relative rounded-lg border border-slate-200 bg-slate-50 p-4 transition-colors
              hover:border-slate-300 dark:border-slate-700 dark:bg-slate-800/50 dark:hover:border-slate-600
            "
          >
            <div class="flex items-start gap-3">
              <div class="grid flex-1 grid-cols-1 gap-4 md:grid-cols-2">
                <div id="key[PLACEHOLDER]_key_input" class="form-field">
                  <%= form.label(
                    "key_PLACEHOLDER",
                    t("projects.samples.metadata.form.field_name"),
                    class:
                      "keyLabel block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2",
                    data: {
                      required: "true",
                    },
                  ) %>

                  <%= form.text_field(
                    "key_PLACEHOLDER",
                    aria: {
                      required: true,
                    },
                    class:
                      "keyInput block px-3 py-2 w-full text-sm text-slate-900 bg-white rounded-md border border-slate-300 appearance-none dark:text-white dark:bg-slate-700 dark:border-slate-600 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:focus:ring-primary-600 dark:focus:border-primary-600 transition-colors",
                  ) %>

                  <div
                    id="sample_key_PLACEHOLDER_error"
                    class="invisible relative z-0 mt-1 min-h-[1.5rem] w-full text-sm"
                  >
                    <%= viral_help_text(state: :error, classes: "hidden") %>
                  </div>
                </div>

                <div id="value[PLACEHOLDER]_value_input" class="form-field">
                  <%= form.label(
                    "value_PLACEHOLDER",
                    t("projects.samples.metadata.form.value"),
                    class:
                      "valueLabel block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2",
                    data: {
                      required: "true",
                    },
                  ) %>

                  <%= form.text_field(
                    "value_PLACEHOLDER",
                    class:
                      "valueInput block px-3 py-2 w-full text-sm text-slate-900 bg-white rounded-md border border-slate-300 appearance-none dark:text-white dark:bg-slate-700 dark:border-slate-600 focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:focus:ring-primary-600 dark:focus:border-primary-600 transition-colors",
                    aria: {
                      required: "true",
                    },
                  ) %>

                  <div
                    id="sample_value_PLACEHOLDER_error"
                    class="invisible relative z-0 mt-1 min-h-[1.5rem] w-full text-sm"
                  >
                    <%= viral_help_text(state: :error, classes: "hidden") %>
                  </div>
                </div>
              </div>

              <button
                id="delete_PLACEHOLDER"
                type="button"
                data-action="projects--samples--metadata--create#removeField"
                class="
                  mt-7 inline-flex h-8 w-8 flex-shrink-0 cursor-pointer items-center justify-center self-start
                  rounded-md text-slate-400 transition-colors hover:bg-slate-200 hover:text-slate-700
                  dark:text-slate-500 dark:hover:bg-slate-700 dark:hover:text-slate-300
                "
                aria-label="<%= t(".remove_field") %>"
              >
                <%= pathogen_icon(:x, size: :sm) %>
              </button>
            </div>
          </div>
        </div>
      </template>

      <div data-projects--samples--metadata--create-target="fieldsContainer" class="space-y-3"></div>

      <div class="text-center">
        <%= form.button t(".create_field_button"),
                    type: "button",
                    class: "button button-default mr-2",
                    "data-action": "projects--samples--metadata--create#addField" %>
      </div>

      <div>
        <%= form.submit t(".submit_button"),
                    class: "button button-primary",
                    "data-action": "projects--samples--metadata--create#buildMetadata" %>
      </div>
    </div>
  <% end %>
</div>
