<turbo-stream action="update" target="selected">
  <template>
    <div
      data-controller="table-selection"
      data-table-selection-ids-value="<%= @sample_attachment_ids %>"
      data-table-selection-selection-outlet="#attachments-table"
    ></div>
  </template>
</turbo-stream>

<%= render template: "shared/selection_limit_exceeded" if @selection_limit_exceeded %>
