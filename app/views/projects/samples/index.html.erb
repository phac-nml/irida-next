<%= turbo_refreshes_with method: :morph, scroll: :preserve %>

<%= turbo_frame_tag "samples_dialog" %>
<%= turbo_frame_tag "samples_alert" %>
<%= turbo_frame_tag "selected" %>
<%= turbo_frame_tag "file_selector_dialog" %>

<div class="fixed-table-component">
  <%= render Viral::PageHeaderComponent.new(
    title: t(".title"),
    subtitle: t(".subtitle", puid: @project.puid),
  ) %>

  <%= render RefreshNoticeComponent.new(
    streamable: @project,
    stream_name: :samples,
    message: t(".refresh_notice.message"),
  ) %>

  <% show_selection_buttons = @has_samples && (
       @allowed_to[:submit_workflow] || @allowed_to[:clone_sample] ||
       @allowed_to[:transfer_sample] || @allowed_to[:export_data]
     ) %>

  <% show_launch = @has_samples && @allowed_to[:submit_workflow] && @pipelines_enabled %>
  <% show_action_band = @has_samples || @render_sample_actions %>

  <% if show_action_band %>
    <div
      class="
        flex min-h-0 flex-1 flex-col overflow-hidden rounded-[var(--pvc-radius-panel)] border
        border-[var(--pvc-color-border)] bg-[var(--pvc-color-surface)]
      "
      data-pathogen--toolbar-surface
    >
      <div
        id="samples-list-action-band"
        class="
          <%= class_names(
          "grid shrink-0 grid-cols-1 items-center gap-2 border-b border-[var(--pvc-color-border)]
          bg-[var(--pvc-color-surface-muted)] px-4 py-3",
          # Stack until md (~768px): Pathogen group reflow alone is not enough in the 640–700 band
          # when Advanced+Search share a second column.
          "md:grid-cols-[minmax(0,1fr)_minmax(12rem,20rem)]": @has_samples,
          ) %>
        "
      >
        <%= render partial: "list_action_band", locals: {
          show_selection_buttons: show_selection_buttons,
          show_launch: show_launch,
          project: @project,
          has_samples: @has_samples,
          render_sample_actions: @render_sample_actions,
          allowed_to: @allowed_to,
          metadata_template: @metadata_template,
          pagy: @pagy,
          results_message: @results_message,
          query: @query,
          advanced_search_fields: @advanced_search_fields,
          search_params: @search_params,
        } %>
      </div>

      <div class="min-h-0 flex-1">
        <%= render partial: "table",
        locals: {
          allowed_to: @allowed_to,
          fields: @fields,
          has_samples: @has_samples,
          pagy: @pagy,
          project: @project,
          samples: @samples,
          search_params: @search_params,
        } %>
      </div>
    </div>
  <% else %>
    <%= render partial: "table",
    locals: {
      allowed_to: @allowed_to,
      fields: @fields,
      has_samples: @has_samples,
      pagy: @pagy,
      project: @project,
      samples: @samples,
      search_params: @search_params,
    } %>
  <% end %>
</div>
