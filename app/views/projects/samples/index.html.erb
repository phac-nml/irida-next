<%= turbo_refreshes_with method: :morph, scroll: :preserve %>

<%= turbo_frame_tag "samples_dialog" %>
<%= turbo_frame_tag "samples_alert" %>
<%= turbo_frame_tag "selected" %>
<%= turbo_frame_tag "file_selector_dialog" %>

<div class="fixed-table-component">
  <%= render Viral::PageHeaderComponent.new(
    title: t('.title'),
    subtitle: t(".subtitle", puid: @project.puid),
  ) %>

  <%= render RefreshNoticeComponent.new(
    streamable: @project,
    stream_name: :samples,
    message: t(".refresh_notice.message"),
  ) %>

  <% show_selection_buttons = @has_samples && (
       @allowed_to[:submit_workflow] || @allowed_to[:clone_sample] ||
         @allowed_to[:transfer_sample] || @allowed_to[:export_data]
     ) %>

  <% show_launch_workflow_button = @allowed_to[:submit_workflow] && @has_samples && @pipelines_enabled %>
  <% show_toolbar = show_selection_buttons || @render_sample_actions || @has_samples || show_launch_workflow_button %>

  <% if show_toolbar %>
    <%= render Pathogen::Toolbar.new(
      label: t("shared.samples.actions_dropdown.label"),
      controls: "samples-table",
      class: "mb-4 w-full flex-wrap gap-2",
    ) do %>
      <% if show_selection_buttons %>
        <%= form_with(
              url: select_namespace_project_samples_url,
              method: :get,
              id: "select-all-form",
              class: "max-sm:w-full",
              data: { turbo_frame: "selected" },
            ) do |f| %>
          <input type="hidden" name="select" value="on">
          <%= render "shared/samples/timestamp_input" %>

          <button
            type="submit"
            id="select-all-button"
            class="button w-full button-default"
            title="<%= t('.select_all_tooltip') %>"
            aria-label="<%= t('.select_all_tooltip') %>"
            data-pathogen--toolbar-target="item"
            tabindex="-1"
          >
            <%= t("common.controls.select_all") %>
          </button>
        <% end %>
        <%= form_with(
              url: select_namespace_project_samples_url,
              method: :get,
              id: "deselect-all-form",
              class: "max-sm:w-full",
              data: { turbo_frame: "selected" },
            ) do |f| %>
          <button
            type="submit"
            id="deselect-all-button"
            class="button w-full button-default"
            title="<%= t('.deselect_all_tooltip') %>"
            aria-label="<%= t('.deselect_all_tooltip') %>"
            data-pathogen--toolbar-target="item"
            tabindex="-1"
          >
            <%= t("common.controls.deselect_all") %>
          </button>
        <% end %>
      <% end %>

      <% if @render_sample_actions %>
        <%= render DropdownComponent.new(label: t("shared.samples.actions_dropdown.label"),
        aria: { label: t('shared.samples.actions_dropdown.label') },
        caret: true,
        classes: "font-normal button button-default",
        system_arguments: {
          tabindex: -1,
          data: {
            'pathogen--toolbar-target': 'item',
          },
        }) do |dropdown| %>
          <% if @allowed_to[:create_sample] %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.new_sample"),
              url: new_namespace_project_sample_path,
              disableable: true,
              data: {
                turbo_stream: true,
              },
              class:
                "flex w-full items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white cursor-pointer",
            ) %>
          <% end %>

          <% if @allowed_to[:clone_sample] %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.clone"),
              url: new_samples_clone_path,
              params: {
                namespace_id: @project.namespace.id,
              },
              disableable: true,
              data: {
                turbo_stream: true,
                controller: "action-button",
                action_button_required_value: 1,
              },
              class:
                "flex w-full items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white action-button cursor-pointer",
            ) %>
          <% end %>

          <% if @allowed_to[:transfer_sample] %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.transfer"),
              url: new_samples_transfer_path,
              params: {
                namespace_id: @project.namespace.id,
              },
              disableable: true,
              data: {
                turbo_stream: true,
                controller: "action-button",
                action_button_required_value: 1,
              },
              class:
                "flex w-full items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white action-button cursor-pointer",
            ) %>
          <% end %>

          <% if @allowed_to[:destroy_sample] %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.delete_samples"),
              url: new_samples_deletions_path,
              params: {
                namespace_id: @project.namespace.id,
                deletion_type: "multiple",
              },
              disableable: true,
              data: {
                turbo_stream: true,
                controller: "action-button",
                action_button_required_value: 1,
              },
              class:
                "flex w-full items-center text-red-600 px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white dark:text-red-300 action-button cursor-pointer",
            ) %>
          <% end %>

          <% if @allowed_to[:update_sample_metadata] || @allowed_to[:import_samples_and_metadata] %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.import"),
              section_header: true,
            ) %>
            <% if @allowed_to[:update_sample_metadata] && @has_samples %>
              <% dropdown.with_item(
                label: t("shared.samples.actions_dropdown.import_metadata"),
                url: new_namespace_project_samples_file_import_path,
                disableable: true,
                data: {
                  turbo_stream: true,
                },
                class:
                  "flex w-full items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white cursor-pointer",
              ) %>
            <% end %>
            <% if @allowed_to[:import_samples_and_metadata] %>
              <% dropdown.with_item(
                label: t("shared.samples.actions_dropdown.import_samples"),
                url: new_namespace_project_samples_spreadsheet_import_path,
                disableable: true,
                data: {
                  turbo_stream: true,
                },
                class:
                  "flex w-full items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white cursor-pointer",
              ) %>
            <% end %>
          <% end %>

          <% if @allowed_to[:export_data] %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.export"),
              section_header: true,
            ) %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.linelist_export"),
              url: new_data_export_path,
              params: {
                export_type: "linelist",
                namespace_id: @project.namespace.id,
              },
              disableable: true,
              data: {
                turbo_stream: true,
                controller: "action-button",
                action_button_required_value: 1,
              },
              class:
                "flex w-full items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white action-button cursor-pointer",
            ) %>
            <% dropdown.with_item(
              label: t("shared.samples.actions_dropdown.sample_export"),
              url: new_data_export_path,
              params: {
                export_type: "sample",
                namespace_id: @project.namespace.id,
              },
              disableable: true,
              data: {
                turbo_stream: true,
                controller: "action-button",
                action_button_required_value: 1,
              },
              class:
                "flex w-full items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white action-button cursor-pointer",
            ) %>
          <% end %>
        <% end %>
      <% end %>

      <% if @has_samples %>
        <div id="table-filter" role="presentation" class="contents">
          <%= render partial: "table_filter", locals: { toolbar_item: true } %>
        </div>
        <%= render MetadataTemplates::DropdownComponent.new(
          url:
            list_namespace_project_metadata_templates_url(
              @project.namespace.parent, @project, metadata_template: @metadata_template[:id],
              limit: @pagy&.limit, page: @pagy&.page
            ),
          toolbar_item: true,
        ) %>
      <% end %>

      <% if show_launch_workflow_button %>
        <%= form_with(
              url: pipeline_selection_workflow_executions_submissions_path,
              method: :get,
              class: "ml-auto max-sm:w-full",
              data: {
                turbo_stream: true,
              },
            ) do %>
          <%= hidden_field_tag :namespace_id, @project.namespace.id %>

          <button
            type="submit"
            class="action-button button w-full cursor-pointer button-default"
            data-controller="action-button"
            data-action-button-required-value="1"
            data-pathogen--toolbar-target="item"
            tabindex="-1"
          >
            <%= icon(:rocket_launch, size: :sm) %>
            <span class="ml-2"><%= t(:".workflows.button_sr") %></span>
          </button>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render partial: "table",
  locals: {
    allowed_to: @allowed_to,
    fields: @fields,
    has_samples: @has_samples,
    pagy: @pagy,
    project: @project,
    samples: @samples,
    search_params: @search_params,
  } %>
</div>
