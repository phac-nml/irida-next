<%= viral_card do |card| %>
  <% card.with_header(title: t(:"projects.edit.advanced.destroy.title")) %>

  <% card.with_section do %>
    <div class="confirm-destroy hidden">
      <div class="mb-4 flex rounded-lg bg-red-50 p-4 text-red-800 dark:bg-slate-800 dark:text-red-400">
        <%= icon(:warning_circle, color: :danger) %>

        <div class="ml-4 flex-1">
          <%= t(
            :"projects.edit.advanced.destroy.confirm.warning.pre_html",
            project_name: @project.human_name,
          ) %>

          <ul class="ml-4 max-w-md list-inside list-disc space-y-1 py-2">
            <li><%= t(
                :"projects.edit.advanced.destroy.confirm.warning.samples_count",
                count: @samples_count,
              ) %></li>

            <li>
              <%= t(
                :"projects.edit.advanced.destroy.confirm.warning.automated_workflows_count",
                count: @automated_workflows_count,
              ) %>
            </li>
          </ul>

          <%= t(:"projects.edit.advanced.destroy.confirm.warning.post_html") %>
        </div>
      </div>

      <div class="mb-4">
        <% t(:"projects.edit.advanced.destroy.confirm.points_html", project: @project.name).each do |item| %>
          <p class="mb-2 text-base text-slate-900 dark:text-white"><%= item %></p>
        <% end %>
      </div>
    </div>

    <p class="text-slate-600 dark:text-slate-400"><%= t(:"projects.edit.advanced.destroy.description") %></p>

    <div class="mt-4">
      <%= button_to t(:"projects.edit.advanced.destroy.submit"),
      namespace_project_path,
      method: :delete,
      data: {
        turbo_confirm: "",
        turbo_content: ".confirm-destroy",
        confirm_value: @project.name,
      },
      class: "button button-destructive" %>
    </div>
  <% end %>
<% end %>
