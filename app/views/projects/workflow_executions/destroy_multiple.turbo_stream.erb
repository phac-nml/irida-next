<% if defined?(messages) %>
  <% messages.each do |message| %>
    <%= turbo_stream.append "flashes" do %>
      <%= pathogen_toast(type: message[:type], message: message[:message]) %>
    <% end %>
  <% end %>
<% else %>
  <%= turbo_stream.append "flashes" do %>
    <%= pathogen_toast(type:, message: message) %>
  <% end %>
<% end %>

<%= turbo_stream.update "workflow_execution_dialog",
                    partial:
                      "shared/workflow_executions/destroy_multiple_confirmation_dialog",
                    locals: {
                      open: false,
                      list_path: @list_path,
                      destroy_path: @destroy_path,
                    } %>

<turbo-stream action="refresh"></turbo-stream>
