<%= turbo_frame_tag "personal_access_token_form" do %>
  <%= form_for(personal_access_token, url: profile_personal_access_tokens_path, html: { novalidate: true }) do |f| %>
    <div class="grid gap-4">
      <%= render partial: "shared/form/required_field_legend" %>

      <%= render partial: "shared/personal_access_tokens/form_fields",
      locals: {
        pat: personal_access_token,
        form: f,
      } %>

      <div class="my-2 flex gap-2">
        <%= render Pathogen::CancelButtonComponent.new(
          data: {
            action: "personal-access-tokens#removeAddNewTokenForm",
            "personal-access-tokens-target": "cancel-button",
          },
        ) %>

        <%= f.submit t("profiles.personal_access_tokens.create.submit"),
                 tone: :primary, emphasis: :solid %>
      </div>
    </div>
  <% end %>
<% end %>
