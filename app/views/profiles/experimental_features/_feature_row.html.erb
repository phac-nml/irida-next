<div id="experimental-feature-<%= feature[:key] %>" class="flex items-center justify-between gap-4 py-1">
  <div class="min-w-0 flex-1">
    <p class="text-sm font-semibold text-slate-800 dark:text-white">
      <%= feature[:name] %>
    </p>

    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
      <%= feature[:description] %>
    </p>
  </div>

  <%= form_with url: profile_experimental_features_path,
                method: :patch,
                data: { controller: "experimental-feature-toggle" } do |f| %>
    <%= f.hidden_field :feature_key, value: feature[:key] %>

    <label class="relative inline-flex cursor-pointer items-center">
      <%= f.check_box :enabled,
            checked: feature[:enabled],
            class: "sr-only",
            aria: { label: t('profiles.experimental_features.toggle_label', feature: feature[:name]) },
            data: {
              action: "change->experimental-feature-toggle#toggle",
              experimental_feature_toggle_target: "checkbox"
            } %>

      <span
        class="relative h-6 w-11 rounded-full after:absolute after:top-[2px] after:left-[2px] after:inline-block after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all after:content-[''] focus-within:outline focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-black dark:focus-within:outline-white <%= feature[:enabled] ? 'bg-primary-600 dark:bg-primary-500 after:translate-x-5' : 'bg-slate-200 dark:bg-slate-700' %>"
        aria-hidden="true"
        data-experimental-feature-toggle-target="pill"
      ></span>
    </label>
  <% end %>

  <div
    id="experimental-feature-<%= feature[:key] %>-status"
    role="alert"
    aria-live="polite"
    class="mt-1 w-full text-sm text-red-600 empty:hidden dark:text-red-400"
  ></div>
</div>
