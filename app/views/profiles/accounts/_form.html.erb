<div>
  <p class="text-base font-normal text-slate-500 md:text-lg dark:text-slate-400">
    <%= t(:"profiles.accounts.delete.description") %>:
  </p>

  <ul class="list-inside list-disc space-y-1 pb-4 text-slate-500 dark:text-slate-400">
    <% t(:'profiles.accounts.delete.effects').each do |val| %>
      <li><%= val %></li>
    <% end %>
  </ul>

  <%= detached_button_to t(:"profiles.accounts.delete.button"),
  profile_account_path,
  data: {
    turbo_method: :delete,
    turbo_confirm: t(:"profiles.accounts.delete.confirm"),
  },
  method: :delete,
  class: "button button-destructive" %>
</div>
