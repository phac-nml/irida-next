<!doctype html>

<html lang="<%= I18n.locale %>">
  <head>
    <title><%= html_head_site_title %></title>
    <%= render "active_admin/html_head" %>
  </head>

  <body class="bg-white text-gray-950 antialiased dark:bg-gray-950/95 dark:text-gray-100">
    <header>
      <%= render "active_admin/site_header", title: site_title %>
    </header>

    <div class="pt-16 xl:ms-60">
      <nav data-controller="active-admin-navigation" inert>
        <%= render "active_admin/main_navigation" %>
      </nav>

      <main>
        <%= render "active_admin/page_header", title: @page_title || page_title %>
        <%= render "active_admin/flash_messages" %>

        <div
          data-test-page-content
          class="grid grid-cols-1 gap-4 px-2.5 lg:auto-cols-[minmax(0,250px)] lg:grid-flow-col lg:gap-6 lg:px-5"
        >
          <%= yield %>
          <%= render "active_admin/sidebar" %>
        </div>
      </main>

      <footer>
        <%= render "active_admin/site_footer" %>
      </footer>
    </div>

    <%= javascript_import_module_tag 'active_admin_navigation' %>
  </body>
</html>
