<% linelist_data = {
  controller:"linelist-import sortable-lists--v1--two-lists-selection",
  "sortable-lists--v1--two-lists-selection-selected-list-value": "selected-list",
  "sortable-lists--v1--two-lists-selection-available-list-value": "available-list",
  "sortable-lists--v1--two-lists-selection-field-name-value": "file_import[metadata_columns][]",
  "linelist-import-sortable-lists--v1--two-lists-selection-outlet": "#import-metadata-dialog-content",
  action: "linelist-import:sendMetadata->sortable-lists--v1--two-lists-selection#updateMetadataListing",
  "linelist-import-refresh-outlet": "[data-controller='refresh']",
  "attachment-upload-uploading-text-value": t('shared.samples.metadata.file_imports.dialog.uploading'),
  "attachment-upload-success-text-value": t('common.upload.uploaded_successfully'),
  "attachment-upload-error-fallback-text-value": t('common.upload.failed'),
  "linelist-import-graphql-url-value": graphql_url,
  "linelist-import-project-puid-value": @project&.puid,
  "linelist-import-group-puid-value": @group&.puid,
  "linelist-import-import-started-message-value": t(".import_started_message"),
  "linelist-import-imported-records-message-value": t(".imported_records_message"),
  "linelist-import-import-complete-message-value": t(".import_complete_message"),
  "linelist-import-error-message-value": t(".error_message"),
} %>

<%= viral_dialog(open: true, size: :large) do |dialog| %>
  <% dialog.with_header(title: t("shared.samples.metadata.file_imports.dialog.title")) %>
  <%= helpers.turbo_stream_from @broadcast_target %>

  <%= helpers.turbo_frame_tag "import_metadata_dialog_content" do %>
    <%= helpers.turbo_frame_tag "import_metadata_dialog_alert" %>

    <%= tag.div id: "import-metadata-dialog-content", data: linelist_data do %>
      <%= form_for(:file_import, url: "#", method: :get, data: { action: "submit->linelist-import#handleSubmit" }) do |form| %>
        <%= render partial: 'shared/samples/metadata/file_imports/form_fields', locals: {
          broadcast_target: @broadcast_target,
          controller: "linelist-import",
          form: form } %>
      <% end %>

      <template data-linelist-import-target="flashTemplate">
        <%= viral_flash(
        type: :success,
        data: t("shared.samples.metadata.file_imports.success.description"),
      ) %>
      </template>

      <template data-linelist-import-target="alertTemplate">
        <%= viral_alert(
                type: :danger,
                message: "PLACEHOLDER",
                classes: class_names("mb-4"),
                dismissible: false,
              ) %>
      </template>

      <template data-linelist-import-target="dialogTemplate">
        <%= viral_dialog(
          size: :large,
          open: false,
          closable: false,
          ) do |dialog| %>
          <% dialog.with_header(title: t("shared.samples.metadata.file_imports.dialog.title")) %>

          <div>
            <p class="mb-4 dark:text-white"><%= t("shared.samples.metadata.file_imports.errors.description") %></p>

            <div id="error-messages"></div>

            <div>
              <%= viral_button(state: :primary, data: { action: 'click->viral--dialog#close' }) do %>
                <%= t("shared.samples.metadata.file_imports.errors.ok_button") %>
              <% end %>
            </div>
          </div>
        <% end %>
      </template>

      <template data-linelist-import-target="progressTemplate">
        <div
          class="
            mt-4 rounded-lg border border-slate-200 bg-slate-50 p-4 shadow-xs dark:border-slate-700
            dark:bg-slate-800/50
          "
        >
          <div class="mb-3 flex items-center justify-between gap-4">
            <div>
              <h4 class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= t(".importing_linelist") %></h4>

              <p class="mt-0.5 text-xs text-slate-600 dark:text-slate-400" data-linelist-import-progress-message></p>
            </div>

            <button
              type="button"
              data-linelist-import-dismiss="true"
              class="
                inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white
                text-slate-500 transition-colors hover:bg-slate-50 hover:text-slate-700 focus:ring-2
                focus:ring-slate-300 focus:ring-offset-2 focus:outline-hidden dark:border-slate-600
                dark:bg-slate-800 dark:text-slate-400 hover:dark:bg-slate-700 hover:dark:text-slate-200
                focus:dark:ring-slate-600 focus:dark:ring-offset-slate-900
              "
              aria-label="<%= t('.close_progress') %>"
            >
              <%= icon(:x, class: "size-4") %>
            </button>
          </div>

          <div class="flex items-center gap-3">
            <div class="relative h-2.5 flex-1 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-700">
              <div
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                aria-label="<%= t('.imported_records_message', current: 0, total: 0) %>"
                class="
                  absolute inset-y-0 left-0 rounded-full bg-primary-600 transition-all duration-300 ease-out
                  dark:bg-primary-500
                "
                style="width: 0%"
                data-linelist-import-progress-bar
              ></div>
            </div>

            <span
              class="w-10 text-right text-xs font-medium text-slate-700 dark:text-slate-300"
              data-linelist-import-progress-percent
            >
              0%
            </span>
          </div>
        </div>
      </template>
    <% end %>
  <% end %>
<% end %>
