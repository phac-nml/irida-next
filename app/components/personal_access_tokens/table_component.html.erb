<% if @personal_access_tokens.size.positive? %>
  <%= viral_data_table(@personal_access_tokens, id: "access-tokens-table") do |table| %>
    <% table.with_column(t("personal_access_tokens.table.header.name")) do |row| %>
      <%= row[:name] %>
    <% end %>

    <% table.with_column(t("personal_access_tokens.table.header.status")) do |row| %>
      <% row_status = row_token_status(row) %>
      <%= viral_pill(color: row_status[:color], text: row_status[:text], classes: "token-status") %>
    <% end %>

    <% table.with_column(t("personal_access_tokens.table.header.scopes")) do |row| %>
      <%= row[:scopes].join(", ") %>
    <% end %>

    <% if show_integration_host? && !@namespace.present? %>
      <% table.with_column(t("personal_access_tokens.table.header.integration_host")) do |row| %>
        <%= row[:integration_host] %>
      <% end %>
    <% end %>

    <% table.with_column(t("personal_access_tokens.table.header.created_at")) do |row| %>
      <%= helpers.local_date(row[:created_at], :long) %>
    <% end %>

    <% table.with_column(t("personal_access_tokens.table.header.last_used_at")) do |row| %>
      <% if row[:last_used_at].present? %>
        <%= helpers.local_date(row[:last_used_at], :long) %>
      <% else %>
        <%= t("personal_access_tokens.table.never") %>
      <% end %>
    <% end %>

    <% if @revoked_pats %>
      <% table.with_column(t("personal_access_tokens.table.header.revocation_date")) do |row| %>
        <% if row[:revoked] == true %>
          <%= helpers.local_date(row[:updated_at], :long) %>
        <% end %>
      <% end %>
    <% end %>

    <% table.with_column(t("personal_access_tokens.table.header.expires_at")) do |row| %>
      <% if row[:expires_at].present? %>
        <%= helpers.local_date(row[:expires_at], :long) %>
      <% else %>
        <%= t("personal_access_tokens.table.never") %>
      <% end %>
    <% end %>

    <% if !@actions.empty? %>
      <% table.with_column(t("personal_access_tokens.table.header.action"),
          classes: "flex justify-start"
        ) do |row| %>
        <% if @actions[:revoke] %>
          <%= button_to t("personal_access_tokens.table.revoke"),
          revoke_path(row),
          data: revoke_data_attributes,
          method: revoke_http_method,
          aria: {
            label: t(:"personal_access_tokens.table.revoke_aria_label", name: row[:name]),
          },
          class:
            "bg-white dark:bg-slate-800 font-medium text-blue-600 underline dark:text-blue-400 hover:decoration-2 cursor-pointer mr-2" %>
        <% end %>

        <% if @actions[:rotate] %>
          <%= button_to t("personal_access_tokens.table.rotate"),
          rotate_path(row),
          data: rotate_data_attributes,
          method: :put,
          aria: {
            label: t(:"personal_access_tokens.table.rotate_aria_label", name: row[:name]),
          },
          class:
            "bg-white dark:bg-slate-800 font-medium text-blue-600 underline dark:text-blue-400 hover:decoration-2 cursor-pointer" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% else %>
  <div class="empty_state_message">
    <%= viral_empty(
      title: @empty[:title],
      description: @empty[:description],
      icon_name: PersonalAccessToken.icon,
    ) %>
  </div>
<% end %>
