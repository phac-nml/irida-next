<div class="mb-2 flex items-center justify-between">
  <button
    type="button"
    class="
      prev-btn mr-2 rounded-lg bg-white p-2.5 text-lg not-aria-disabled:cursor-pointer
      not-aria-disabled:text-slate-800 not-aria-disabled:hover:bg-slate-100 not-aria-disabled:hover:text-slate-900
      aria-disabled:cursor-not-allowed dark:bg-slate-700 not-aria-disabled:dark:text-white
      not-aria-disabled:dark:hover:bg-slate-600 not-aria-disabled:dark:hover:text-white
    "
    data-action="
        click->combobox-datepicker--v1--calendar#previousMonth
      "
    data-combobox-datepicker--v1--calendar-target="backButton"
    aria-label="<%= t("components.datepicker.aria_label.previous_month_button") %>"
  >
    <%= icon(:arrow_left, color: nil, size: nil, class: "size-6") %>
  </button>

  <div data-combobox-datepicker--v1--calendar-target="monthSelectContainer"></div>

  <div>
    <input
      data-combobox-datepicker--v1--calendar-target="year"
      data-action="change->combobox-datepicker--v1--calendar#changeYear"
      type="number"
      autocomplete="off"
      max="9999"
      min="<%= @min_year %>"
      class="
        ml-1 w-22 rounded-lg border-slate-300 text-slate-900 max-[384px]:w-18 max-[384px]:px-[0.6rem]
        max-[384px]:py-[0.25rem] sm:text-sm dark:border-slate-600 dark:bg-slate-800 dark:text-white
      "
      aria-label="<%= t('components.datepicker.aria_label.select_year') %>"
      name="year-select"
    >
  </div>

  <button
    type="button"
    class="
      next-btn ml-2 cursor-pointer rounded-lg bg-white p-2.5 text-lg text-slate-800 hover:bg-slate-100
      hover:text-slate-900 dark:bg-slate-700 dark:text-white dark:hover:bg-slate-600 dark:hover:text-white
    "
    data-action="click->combobox-datepicker--v1--calendar#nextMonth"
    aria-label="<%= t("components.datepicker.aria_label.next_month_button") %>"
  >
    <%= icon(:arrow_right, color: nil, size: nil, class: "size-6") %>
  </button>

  <div
    data-combobox-datepicker--v1--calendar-target="headerAriaLive"
    id="<%= @calendar_id %>-header"
    aria-live="polite"
    class="sr-only"
  ></div>
</div>

<template data-combobox-datepicker--v1--calendar-target="monthSelectTemplate">
  <select
    data-combobox-datepicker--v1--calendar-target="monthSelect"
    data-action="change->combobox-datepicker--v1--calendar#changeMonth"
    class="
      rounded-lg border-slate-300 text-slate-900 max-[384px]:py-[0.25rem] max-[384px]:pr-[2.35rem]
      max-[384px]:pl-[0.6rem] sm:text-sm dark:border-slate-600 dark:bg-slate-800 dark:text-white
    "
    aria-label="<%= t('components.datepicker.aria_label.select_month') %>"
    name="month-select"
  >
    <% @months.each do |month| %>
      <option value="<%= month %>"><%= month %></option>
    <% end %>
  </select>
</template>
