<% if @label %>
  <label for="<%= @input_id %>" class="mb-2 block w-fit text-sm font-medium text-slate-900 dark:text-white">
    <%= @label %>

    <% if @required %>
      <abbr class="req" title="<%= t('pathogen.label.title') %>"><%= t("pathogen.label.required_indicator") %></abbr>
    <% end %>
  </label>
<% end %>

<div class="relative max-w-sm" aria-live="polite">
  <div class="pointer-events-none absolute inset-y-0 inset-s-0 flex items-center ps-3.5">
    <%= icon(:calendar_dots, color: nil, size: nil, class: "size-6 text-slate-500 dark:text-slate-400") %>
  </div>

  <input
    placeholder="<%= t("components.datepicker.placeholder") %>"
    autocomplete="off"
    value="<%= @selected_date %>"
    data-combobox-datepicker--v1--input-target="datepickerInput"
    data-action="
      keydown->combobox-datepicker--v1--input#handleKeyboardInput
      click->combobox-datepicker--v1--input#toggleCalendar
    "
    type="text"
    name="<%= @input_name %>"
    id="<%= @input_id %>"
    class="
      min-w-full rounded-lg border-slate-300 px-10 py-2.5 text-sm text-slate-900 dark:border-slate-600
      dark:bg-slate-800 dark:text-white dark:placeholder-slate-400
    "
    role="combobox"
    aria-haspopup="dialog"
    aria-autocomplete="none"
    aria-expanded="false"
    <% if @input_aria_label %>
      aria-label="<%= @input_aria_label %>"
    <% end %>
    <% if @required %>
      aria-required="true"
    <% end %>
    <% if @errored %>
      aria-describedby="<%= @error_id %>"
      aria-invalid="true"
    <% end %>
  >

  <div class="absolute inset-y-0 right-0 z-10 flex items-center">
    <button
      data-action="click->combobox-datepicker--v1--input#toggleCalendar"
      class="
        flex h-full w-10 cursor-pointer items-center justify-center rounded-r-lg text-slate-500 transition-colors
        hover:bg-slate-100 focus-visible:outline-3 dark:text-slate-300 dark:hover:bg-slate-700
      "
      tabindex="-1"
      type="button"
      aria-label="<%= I18n.t("components.datepicker.aria_label.dialog") %>"
    >
      <div data-combobox-datepicker--v1--input-target="inputArrow">
        <%= icon(:caret_down, color: :subdued, size: :sm) %>
      </div>
    </button>
  </div>
</div>
