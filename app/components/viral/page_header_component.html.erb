<section class="mb-6 w-full">
  <div class="flex w-full flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
    <!-- Header Content -->
    <div class="flex min-w-0 flex-1 flex-col gap-3">
      <!-- Icon and Title Row -->
      <div class="flex items-start gap-3">
        <% if icon.present? %>
          <div class="mt-1 flex-shrink-0">
            <%= icon %>
          </div>
        <% end %>

        <div class="min-w-0 flex-1">
          <%= pathogen_heading(level: 1, class: "break-words") do %>
            <%= title %>
          <% end %>
        </div>
      </div>

      <!-- Subtitle -->
      <% if subtitle.present? %>
        <div class="<%= icon? ? 'pl-12' : '' %>">
          <%= pathogen_supporting(variant: :muted, class: "break-words") do %>
            <%= subtitle %>
          <% end %>
        </div>
      <% end %>

      <!-- PUID (Mobile: Last element, Desktop: After subtitle) -->
      <% if @id %>
        <div class="order-last lg:order-none <%= icon? ? 'pl-12' : '' %>">
          <div class="inline-block">
            <%= render PuidComponent.new(puid: id) %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Action Buttons -->
    <% if buttons? %>
      <div
        class="
          flex w-full flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:gap-2 lg:w-auto lg:flex-shrink-0
          lg:self-start
        "
      >
        <%= buttons %>
      </div>
    <% end %>
  </div>
</section>
