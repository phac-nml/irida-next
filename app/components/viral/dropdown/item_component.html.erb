<li>
  <%= link_to url, class: "flex items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600 dark:hover:text-white", **system_arguments do %>
    <% if @icon_name.present? %>
      <span class="grow-0 mr-2">
        <%= item_icon %>
      </span>
    <% end %>
    <%= label %>
  <% end %>
</li>
