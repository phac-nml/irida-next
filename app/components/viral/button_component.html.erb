<%= render Viral::BaseComponent.new(tag: 'button', **system_arguments) do %>
  <% if content.present? %>
    <span class="pointer-events-none"><%= content %></span>
  <% end %>

  <% if disclosure.present? %>
    <% case disclosure %>
    <% when :down %>
      <%= icon(:caret_down, size: :sm, class: "ml-2") %>
    <% when :up %>
      <%= icon(:caret_up, size: :sm, class: "ml-2") %>
    <% when :right %>
      <%= icon(:caret_right, size: :sm, class: "ml-2") %>
    <% end %>
  <% end %>
<% end %>
