<%= render Viral::BaseComponent.new(tag: "div", **system_arguments) do %>
  <h1 class="dialog--title"><%= title %></h1>

  <%= tag.button(
    class: "dialog--close cursor-pointer",
    type: "button",
    hidden: !@closable,
    data: {
      action: "click->viral--dialog#handleClose",
      "viral--dialog-target": "closeButton"
    },
    aria: { label: t(:"components.dialog.close") }
  ) do %>
    <%= icon(:x, size: :sm) %>
  <% end %>
<% end %>
