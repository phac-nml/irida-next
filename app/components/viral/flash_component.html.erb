<div
  data-controller="viral--flash"
  data-viral--flash-timeout-value="<%= timeout %>"
  data-viral--flash-type-value="<%= type %>"
  id="<%= component_id %>"
  class="
    mb-4 flex w-full max-w-md transform items-start rounded-xl border border-slate-200 bg-white p-4 text-slate-700
    shadow-lg transition-all duration-300 ease-out dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300
  "
  role="alert"
  aria-live="assertive"
  aria-atomic="true"
  aria-describedby="<%= component_id %>-message"
  data-turbo-permanent="true"
  style="opacity: 0; transform: translateY(-20px) scale(0.95);"
>
  <!-- Icon container - hidden from screen readers but visible -->
  <div
    class="mt-0.5 mr-3 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg <%= icon_container_classes %>"
    aria-hidden="true"
  >
    <%= icon(icon_name, size: :md, color: icon_color) %>
  </div>

  <!-- Message content -->
  <div
    id="<%= component_id %>-message"
    class="min-w-0 flex-1 text-sm leading-relaxed text-slate-800 dark:text-slate-200"
  >
    <span class="sr-only"><%= message_type_sr_text %>:</span>
    <%= data %>
  </div>

  <!-- Close button -->
  <button
    type="button"
    data-action="viral--flash#dismiss"
    class="
      -mt-1 -mr-1 ml-3 inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-lg bg-white p-1.5
      text-slate-400 transition-colors duration-200 hover:bg-slate-100 hover:text-slate-600 dark:bg-slate-800
      dark:text-slate-500 dark:hover:bg-slate-700 dark:hover:text-slate-300
    "
    aria-label="<%= t('general.screen_reader.close') %>"
  >
    <%= icon(:x, size: :sm, color: :subdued) %>
  </button>
</div>
