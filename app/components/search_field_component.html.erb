<%= render Viral::BaseComponent.new(tag: :div, **system_arguments) do %>
  <%= @form.label @field_name, @label, class: "sr-only" %>

  <div class="<%= field_shell_classes %>">
    <%= @form.search_field @field_name,
                       "data-search-field-target": "input",
                       "data-pathogen--toolbar-target": (@toolbar_item ? "item" : nil),
                       tabindex: (@toolbar_item ? -1 : nil),
                       "data-test-selector":
                         !Rails.env.production? ? "search-field-input" : nil,
                       class: field_input_classes,
                       aria: {
                         description:
                           t("components.search_field_component.instructions"),
                       },
                       placeholder: @placeholder,
                       value: @value %>

    <!-- Clear button (shown only when there are existing search results) -->
    <button
      type="button"
      data-search-field-target="clearButton"
      data-action="click->search-field#beforeSubmit click->search-field#clear"
      <% if @toolbar_item %>
        data-pathogen--toolbar-target="item"
        tabindex="-1"
      <% end %>
      class="<%= class_names(field_action_classes, clear_button? ? nil : "hidden") %>"
      aria-label="<%= t('components.search_field_component.clear_button') %>"
    >
      <%= icon(:x, size: :sm, color: :subdued) %>
    </button>

    <!-- Submit/search button (hidden while clear button is active) -->
    <button
      type="submit"
      data-search-field-target="submitButton"
      data-action="
        click->search-field#beforeSubmit
        click->search-field#clearSelection
        click->search-field#updateFocus
      "
      <% if @toolbar_item %>
        data-pathogen--toolbar-target="item"
        tabindex="-1"
      <% end %>
      class="<%= class_names(field_action_classes, clear_button? ? "hidden" : nil) %>"
      aria-label="<%= t('common.controls.search') %>"
    >
      <%= icon(:magnifying_glass, size: :sm, color: :subdued) %>
    </button>
  </div>
<% end %>
