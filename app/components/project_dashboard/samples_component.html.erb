<ol class="@container space-y-4" aria-label="<%= t('.list_aria_label') %>">
  <%# ♿ Add aria-label for screen reader context %>
  <% samples.each do |sample| %>
    <li class="sample">
      <div class="flex gap-3 rounded-lg border border-slate-200 p-3 dark:border-slate-700 <%= tailwind_colors[:bg] %> <%= tailwind_colors[:dark_bg] %>">
        <%# Icon container %>
        <div class="shrink-0">
          <span
            aria-hidden="true"
            <%# ♿ Hide decorative icon from screen readers %>
            class="inline-flex items-center justify-center rounded-lg bg-blue-100 p-2 dark:bg-blue-900/30"
          >
            <%# Icon color - accessible dark blue %>
            <%= icon(Sample.icon, size: :sm, color: :blue) %>
          </span>
        </div>

        <%# Content container %>
        <div class="min-w-0 flex-1 space-y-2">
          <%# Sample name with improved wrapping %>
          <div>
            <%= link_to sample.name,
            sample_path(sample),
            class:
              "underline hover:decoration-2 font-medium text-slate-900 dark:text-slate-300 dark:text-white break-words leading-tight" %>
          </div>

          <%# Metadata row - stacks vertically on small screens/high zoom %>
          <div class="flex flex-col gap-2 @sm:flex-row @sm:items-center @sm:gap-4">
            <%# PUID - allows wrapping %>
            <div class="min-w-0 flex-1"><%= render PuidComponent.new(puid: sample.puid, show_clipboard: true) %></div>

            <%# Timestamp %>
            <div class="shrink-0">
              <time
                class="text-xs whitespace-nowrap text-slate-500 dark:text-slate-400"
                datetime="<%= sample.updated_at.iso8601 %>"
                title="<%= t('.last_updated_title', time: helpers.local_date(sample.updated_at, :long)) %>"
              >
                <%= helpers.local_time(sample.updated_at, :short_no_year) %>
              </time>
            </div>
          </div>
        </div>
      </div>
    </li>
  <% end %>
</ol>
