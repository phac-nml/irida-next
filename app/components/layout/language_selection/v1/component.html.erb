<div class="inline-flex items-center">
  <%= render DropdownComponent.new(
    icon: :translate,
    label: I18n.t(:"locales.#{locale}", locale: locale),
    trigger_id: "language-selection-dd-trigger",
    skidding: 0,
    distance: 5,
    styles: {
      button: "button button-default px-3",
      dropdown: "w-32 z-30",
    },
    aria: {
      label: t(:'components.layout.language_selection.title'),
    },
  ) do |dropdown| %>
    <% dropdown.with_custom_item do %>
      <% @locale_options.each do |locale_name, locale_value| %>
        <% if locale == locale_value %>
          <li
            role="menuitemradio"
            aria-checked="true"
            aria-label="<%= locale_name %>"
            class="
              flex w-full items-center border-slate-100 bg-slate-100 px-4 py-2 text-slate-600 hover:bg-slate-100
              dark:border-slate-600 dark:bg-slate-600 dark:text-slate-300 dark:hover:bg-slate-600
              dark:hover:text-white
            "
          >
            <%= locale_name %>
          </li>
        <% else %>
          <li
            role="menuitemradio"
            aria-checked="false"
            aria-label="<%= locale_name %>"
            lang="<%= locale_value %>"
            class="
              flex w-full cursor-pointer items-center px-4 py-2 hover:bg-slate-100 dark:hover:bg-slate-600
              dark:hover:text-white
            "
          >
            <%= form_with(model: @user, url: profile_preferences_path, method: :patch) do |form| %>
              <%= form.hidden_field :locale,
                                value: locale_value,
                                id: "language_selection_#{locale_value}" %>

              <%= form.submit locale_name,
                          class: "cursor-pointer",
                          "aria-hidden": "true",
                          tabindex: "-1" %>
            <% end %>
          </li>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
