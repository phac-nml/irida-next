<%= tag.div(class: "flex max-sm:grow",
            data: {
              controller: tooltip? ? "pathogen--tooltip dropdown--v2" : "dropdown--v2",
              "dropdown--v2-distance-value": distance,
            }) do %>
  <%= render Pathogen::Button.new(tone: :neutral, emphasis: :outline, text: label.presence, **system_arguments) do |button| %>
    <% if icon_name.present? %>
      <% button.with_leading_visual do %>
        <%= icon(
          icon_name,
          size: icon_size,
          class: class_names({ "size-5": icon_size.nil? }),
        ) %>
      <% end %>
    <% end %>

    <% if caret %>
      <% button.with_trailing_visual do %>
        <span data-dropdown--v2-target="caret" class="inline-flex flex-none"><%= icon(:caret_down, size: :sm) %></span>
      <% end %>
    <% end %>

    <% if prefix.present? %>
      <span class="sr-only"><%= prefix %>&nbsp;</span>
    <% end %>

    <% if label.present? %>
      <%= tag.span(class: class_names("truncate", styles[:label])) do %>
        <%= label %>
      <% end %>
    <% end %>
  <% end %>

  <%= render tooltip_component if tooltip? %>

  <!-- Dropdown menu -->
  <%= tag.ul(id: @dd_id,
             data: { "dropdown--v2-target": "menu" },
             role: "menu",
             class: class_names("z-20 w-max rounded-lg border border-slate-200 bg-white py-2 text-sm text-slate-700 shadow dark:border-slate-800 dark:bg-slate-700 dark:text-slate-200", styles[:dropdown]),
             aria: { labelledby: system_arguments[:id] },
             aria_hidden: true,
             tabindex: -1,
             hidden: true) do %>
    <% items.each do |item| %>
      <%= item %>
    <% end %>
  <% end %>
<% end %>
