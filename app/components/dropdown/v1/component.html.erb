<div
  class="flex max-sm:grow"
  data-controller="dropdown--v1<%= tooltip? ? ' pathogen--tooltip' : '' %>"
  data-dropdown--v1-skidding-value="<%= skidding %>"
  data-dropdown--v1-distance-value="<%= distance %>"
>
  <%= render Pathogen::Button.new(
    tone:,
    emphasis:,
    size:,
    icon_only: label.blank? && !caret && prefix.blank?,
    text: label.presence,
    **system_arguments
  ) do |button| %>
    <% if icon_name.present? %>
      <% button.with_leading_visual do %>
        <%= icon(
          icon_name,
          size: icon_size,
          class: class_names({ "size-5": icon_size.nil? }),
        ) %>
      <% end %>
    <% end %>

    <% if caret %>
      <% button.with_trailing_visual do %>
        <span data-dropdown--v1-target="caret" class="inline-flex flex-none"><%= icon(:caret_down, size: :sm) %></span>
      <% end %>
    <% end %>

    <% if prefix.present? %>
      <span class="sr-only"><%= prefix %>&nbsp;</span>
    <% end %>

    <% if label.present? %>
      <%= tag.span(class: class_names("truncate", styles[:label])) do %>
        <%= label %>
      <% end %>
    <% end %>
  <% end %>

  <%= render tooltip_component if tooltip? %>

  <!-- Dropdown menu -->
  <ul
    id="<%= @dd_id %>"
    data-dropdown--v1-target="menu"
    role="menu"
    class="z-20 mx-3 w-max rounded-lg border border-slate-200 bg-white py-2 text-sm text-slate-700 shadow dark:border-slate-800 dark:bg-slate-700 dark:text-slate-200 <%= styles[:dropdown] %>"
    aria-labelledby="<%= system_arguments[:id] %>"
    aria-hidden="true"
    tabindex="-1"
    hidden
  >
    <% items.each do |item| %>
      <%= item %>
    <% end %>
  </ul>
</div>
