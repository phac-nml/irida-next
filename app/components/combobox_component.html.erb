<div
  data-controller="combobox"
  data-combobox-no-results-text-value="<%= t(".no_results_text") %>"
  data-combobox-single-result-text-value="<%= t(".single_result_text") %>"
  data-combobox-multiple-results-text-value="<%= t(".multiple_results_text") %>"
>
  <%= @form.hidden_field @field,
                     value: @selected_option[:value],
                     id: "#{@combobox_id}_hidden",
                     data: {
                       "combobox-target": "hidden",
                     } %>

  <%= render Viral::BaseComponent.new(**combobox_arguments) %>

  <div
    id="<%= @listbox_id %>"
    role="listbox"
    aria-label="<%= combobox_arguments[:aria][:label] %>"
    data-combobox-target="listbox"
    style="position-anchor: --anchor-<%= @listbox_id %>;"
  >
    <%= @listbox_options %>
  </div>

  <div class="sr-only" aria-live="polite" data-combobox-target="ariaLiveUpdate"></div>
</div>
