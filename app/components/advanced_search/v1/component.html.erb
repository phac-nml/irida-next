<%= tag.div(
  data: {
    controller: "advanced-search--v1",
    action: "input->advanced-search--v1#clearSubmitError change->advanced-search--v1#clearSubmitError",
    "advanced-search--v1-open-value": @open,
    "advanced-search--v1-status-value": @status,
    "advanced-search--v1-confirm-close-text-value": t("components.advanced_search_component.v1.confirm_close_text"),

    "advanced-search--v1-list-filter-outlet": ".list-filter",
  },
) do %>
  <%= viral_dialog(id: 'advanced-search-dialog', size: :large, open: @open, header_system_arguments: {close_action: "advanced-search--v1#close"}, data: { action: "keydown.esc->advanced-search--v1#close"}) do |dialog| %>
    <% dialog.with_trigger do %>
      <div class="flex w-full grow flex-row rounded-lg" role="group">
        <button
          type="button"
          class="<%= class_names("button button-default w-full focus-visible:z-10", { "rounded-e-none border-e-0": @status }) %>"
          data-viral--dialog-target="trigger"
          data-action="advanced-search--v1#renderSearch viral--dialog#open"
          aria-label="<%= t("components.advanced_search_component.v1.title") %>"
        >
          <%= t("components.advanced_search_component.v1.title") %>
        </button>

        <% if @status %>
          <button
            type="button"
            class="button rounded-s-none button-default"
            data-action="advanced-search--v1#clearForm filters#submit"
            aria-label="<%= t("components.advanced_search_component.v1.clear_aria_label") %>"
          >
            <%= pathogen_icon(:x, size: :sm) %>
          </button>
        <% end %>
      </div>
    <% end %>

    <% dialog.with_header(title: t("components.advanced_search_component.v1.title")) %>

    <div class="space-y-4">
      <p class="text-base leading-relaxed text-slate-500 dark:text-slate-400">
        <%= t("components.advanced_search_component.v1.description") %>
      </p>

      <p class="text-base leading-relaxed text-slate-500 dark:text-slate-400">
        <%= t("components.advanced_search_component.v1.rules") %>
      </p>

      <div class="mb-4"><%= render partial: "shared/form/required_field_legend" %></div>

      <div class="hidden" data-advanced-search--v1-target="submitError">
        <%= render Viral::AlertComponent.new(
          type: :danger,
          message: t("components.advanced_search_component.v1.minimum_condition_error"),
          dismissible: false,
        ) %>
      </div>

      <div class="space-y-4" data-advanced-search--v1-target="searchGroupsContainer"></div>

      <div class="flex justify-end space-x-2">
        <%= viral_button(data: { action: "advanced-search--v1#addGroup" }) do %>
          <%= t("components.advanced_search_component.v1.add_group_button") %>
        <% end %>
      </div>

      <template data-advanced-search--v1-target="searchGroupsTemplate">
        <% @search.groups.each_with_index do |group, group_index| %>
          <%= render AdvancedSearch::V1::Group.new(
            form: @form,
            group: group,
            group_index: group_index,
            group_number: group_index + 1,
            show_remove_group_button: @search.groups.count > 1,
            fields: @fields,
            operations: @operations,
          ) %>
        <% end %>
      </template>
    </div>

    <% dialog.with_primary_action(
      "data-action": "advanced-search--v1#submit filters#submit",
    ) { t("components.advanced_search_component.v1.apply_filter_button") } %>

    <% dialog.with_secondary_action do %>
      <%= viral_button(data: { action: "advanced-search--v1#clearForm filters#submit" }) do %>
        <%= t("components.advanced_search_component.v1.clear_filter_button") %>
      <% end %>
    <% end %>
  <% end %>

  <template data-advanced-search--v1-target="listValueTemplate">
    <%= @form.fields_for :groups, @search_group_class.new, child_index: "GROUP_INDEX_PLACEHOLDER" do |group_form| %>
      <% condition = @search_condition_class.new(operator: "in") %>

      <%= group_form.fields_for :conditions, condition, child_index: "CONDITION_INDEX_PLACEHOLDER" do |conditions_form| %>
        <%= render AdvancedSearch::V1::Value.new(
          conditions_form: conditions_form,
          group_index: "GROUP_INDEX_PLACEHOLDER",
          condition: condition,
          condition_index: "CONDITION_INDEX_PLACEHOLDER",
        ) %>
      <% end %>
    <% end %>
  </template>

  <template data-advanced-search--v1-target="valueTemplate">
    <%= @form.fields_for :groups, @search_group_class.new, child_index: "GROUP_INDEX_PLACEHOLDER" do |group_form| %>
      <% condition = @search_condition_class.new(operator: "=") %>

      <%= group_form.fields_for :conditions, condition, child_index: "CONDITION_INDEX_PLACEHOLDER" do |conditions_form| %>
        <%= render AdvancedSearch::V1::Value.new(
          conditions_form: conditions_form,
          group_index: "GROUP_INDEX_PLACEHOLDER",
          condition: condition,
          condition_index: "CONDITION_INDEX_PLACEHOLDER",
        ) %>
      <% end %>
    <% end %>
  </template>

  <template data-advanced-search--v1-target="conditionTemplate">
    <%= @form.fields_for :groups, @search_group_class.new, child_index: "GROUP_INDEX_PLACEHOLDER" do |group_form| %>
      <%= render AdvancedSearch::V1::Condition.new(
        groups_form: group_form,
        group_index: "GROUP_INDEX_PLACEHOLDER",
        condition: @search_condition_class.new,
        condition_index: "CONDITION_INDEX_PLACEHOLDER",
        condition_number: "CONDITION_LEGEND_INDEX_PLACEHOLDER",
        fields: @fields,
        operations: @operations,
      ) %>
    <% end %>
  </template>

  <template data-advanced-search--v1-target="groupTemplate">
    <%= render AdvancedSearch::V1::Group.new(
      form: @form,
      group: @search_group_class.new,
      group_index: "GROUP_INDEX_PLACEHOLDER",
      group_number: "GROUP_LEGEND_INDEX_PLACEHOLDER",
      show_remove_group_button: true,
      fields: @fields,
      operations: @operations,
    ) %>
  </template>
<% end %>
