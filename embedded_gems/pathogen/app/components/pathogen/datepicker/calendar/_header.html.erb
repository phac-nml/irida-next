<div>
  <div
    class="
      bg-white dark:bg-slate-700 dark:text-white px-2 py-3 text-center font-semibold
    "
    style="display: none;"
  ></div>
  <div class="flex justify-between mb-2">
    <button
      type="button"
      class="
        bg-white dark:bg-slate-700 rounded-lg enabled:text-slate-800
        enabled:dark:text-white enabled:hover:bg-slate-100
        enabled:dark:hover:bg-slate-600 enabled:hover:text-slate-900
        enabled:dark:hover:text-white text-lg p-2.5 prev-btn mr-2 enabled:cursor-pointer
        disabled:cursor-not-allowed
      "
      data-action="
        click->pathogen--datepicker--calendar#previousMonth
        keydown->pathogen--datepicker--calendar#tabBackToInput
      "
      data-pathogen--datepicker--calendar-target="backButton"
      aria-label="<%= t("pathogen.datepicker.aria_label.previous_month_button")%>"
    >
      <%= pathogen_icon(:arrow_left, size: :sm) %>
    </button>
    <div>
      <%= render(Pathogen::DropdownMenu.new(placement: :bottom_start, offset: 4)) do |menu| %>
        <% menu.with_trigger(
          aria_label: t('pathogen.datepicker.aria_label.select_month'),
          class: 'rounded-lg border border-slate-300 text-slate-900 sm:text-sm dark:border-slate-600 dark:bg-slate-800 dark:text-white px-3 py-2',
          data: {
            action: 'keydown->pathogen--datepicker--calendar#tabBackToInput',
            'pathogen--datepicker--calendar-target' => 'monthTrigger'
          }
        ) do %>
          <span class="inline-flex items-center gap-2">
            <span data-pathogen--datepicker--calendar-target="monthLabel"></span>
            <%= pathogen_icon(
              :caret_down,
              size: :sm,
              class: "text-slate-500 dark:text-slate-300",
            ) %>
          </span>
        <% end %>

        <% months.each_with_index do |month, month_index| %>
          <% menu.with_item(
            label: month,
            data: {
              :action => "click->pathogen--datepicker--calendar#selectMonth",
              :month_index => month_index,
              "pathogen--datepicker--calendar-target" => "monthItem",
              "pathogen--datepicker--calendar-month-index-param" => month_index,
            },
          ) %>
        <% end %>
      <% end %>
    </div>
    <div>
      <input
        data-pathogen--datepicker--calendar-target="year"
        data-action="change->pathogen--datepicker--calendar#changeYear"
        type="number"
        max="9999"
        min="<%= min_year %>"
        class="
          w-22 rounded-lg border-slate-300 text-slate-900 sm:text-sm dark:border-slate-600
          dark:bg-slate-800 dark:text-white ml-1
        "
        aria-label="<%= t('pathogen.datepicker.aria_label.select_year') %>"
      >
    </div>
    <button
      type="button"
      class="
        bg-white dark:bg-slate-700 rounded-lg text-slate-800 dark:text-white
        hover:bg-slate-100 dark:hover:bg-slate-600 hover:text-slate-900
        dark:hover:text-white text-lg p-2.5 next-btn ml-2 cursor-pointer
      "
      data-action="click->pathogen--datepicker--calendar#nextMonth"
      aria-label="<%= t("pathogen.datepicker.aria_label.next_month_button")%>"
    >
      <%= pathogen_icon(:arrow_right, size: :sm) %>
    </button>
  </div>
</div>
