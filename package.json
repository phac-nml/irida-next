{
  "name": "irida-next",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@herb-tools/formatter": "^0.9.5",
    "@herb-tools/linter": "^0.9.5",
    "axe-core": "^4.11.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "playwright": "1.58.2",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "scripts": {
    "herb:format": "herb-format",
    "herb:format:check": "herb-format --check",
    "herb:lint": "herb-lint",
    "format": "pnpm run herb:format && prettier --write '**/*.{js,jsx,ts,tsx,css,json,md,yml,yaml}'",
    "format:check": "pnpm run herb:format:check && prettier --check '**/*.{js,jsx,ts,tsx,css,json,md,yml,yaml}'",
    "format:changed": "prettier --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:css": "pnpx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify",
    "dev:css": "pnpx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify --watch"
  },
  "dependencies": {
    "@tailwindcss/cli": "4.2.2",
    "flowbite": "^3.1.2",
    "tailwindcss": "4.2.2"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
