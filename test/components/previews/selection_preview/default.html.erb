<div data-controller="selection">
  <% (0...3).each do |index| %>
    <div class="mb-4 flex items-center">
      <input
        type="checkbox"
        id="item<%= index %>"
        name="item<%= index %>"
        value="item<%= index %>"
        data-action="click->selection#toggle"
        data-selection-target="rowSelection"
        class="
          h-4 w-4 rounded border-slate-300 bg-slate-100 text-blue-600 dark:border-slate-600 dark:bg-slate-700
          dark:ring-offset-slate-800
        "
      >

      <label for="item<%= index %>" class="ml-2 text-sm font-medium text-slate-900 dark:text-slate-300">
        <%= "Item #{index}" %>
      </label>
    </div>
  <% end %>
</div>
