<%= form_with(url: "#", data:
if Flipper.enabled?(:v2_select2)
    { controller: "viral--v2--select2" }
  else
    { controller: "viral--v1--select2" }
  end) do |form| %>
  <label for="unique_id">Select User</label>

  <%= viral_select2(form:, name: :user, id: "unique_id") do |select| %>
    <% (1..50).each do |num| %>
      <% select.with_option(
                      value: num,
                      label: "User #{num}",
                    ) do %>
        <span class="pointer-events-none block font-semibold text-slate-900 dark:text-slate-400">
          <%= "User #{num}" %>
        </span>
      <% end %>

      <%= select.with_empty_state do %>
        No users found
      <% end %>
    <% end %>
  <% end %>

  <%= form.submit "Submit",
              class: "button button-primary",
              disabled: true,
              data:
              if Flipper.enabled?(:v2_select2)
                { "viral--v2--select2-target": "submitButton" }
              else
                { "viral--v1--select2-target": "submitButton" }
              end %>
<% end %>
