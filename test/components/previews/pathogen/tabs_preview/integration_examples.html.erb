<div class="min-h-screen bg-gradient-to-br from-emerald-50 to-teal-50 p-8 dark:from-slate-900 dark:to-emerald-950">
  <!-- Header -->
  <div class="mb-12 text-center">
    <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-slate-100">
      <%= icon(:puzzle_piece, color: :primary, size: :xl, class: "inline mr-3") %> Integration Examples
    </h1>

    <p class="mx-auto max-w-3xl text-lg text-slate-600 dark:text-slate-400">
      Real-world patterns for integrating tabs with forms, navigation, data tables, and content organization.
    </p>
  </div>

  <!-- User Profile Example -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:user_circle_plus, color: :primary, class: "mr-3") %> User Profile with Settings
    </h2>

    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <%= render(Pathogen::Tabs.new(
        id: 'profile-tabs',
        label: 'User profile sections',
        sync_url: true
      )) do |tabs| %>
        <% tabs.with_tab(id: 'tab-profile', label: 'Profile', selected: true) %>
        <% tabs.with_tab(id: 'tab-account', label: 'Account') %>
        <% tabs.with_tab(id: 'tab-security', label: 'Security') %>
        <% tabs.with_tab(id: 'tab-notifications', label: 'Notifications') %>

        <% tabs.with_panel(id: 'panel-profile', tab_id: 'tab-profile') do %>
          <div class="space-y-6 p-6">
            <div class="flex items-center gap-6">
              <div
                class="
                  flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-blue-500
                  to-purple-500 text-3xl font-bold text-white
                "
              >
                JD
              </div>

              <div>
                <button
                  class="
                    rounded-md bg-slate-100 px-4 py-2 text-sm text-slate-700 transition-colors hover:bg-slate-200
                    dark:bg-slate-700 dark:text-slate-300 dark:hover:bg-slate-600
                  "
                >
                  Change Photo
                </button>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">First Name</label>

                <input
                  type="text"
                  autocomplete="given-name"
                  value="John"
                  class="
                    w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                    dark:border-slate-600 dark:bg-slate-700 dark:text-white
                  "
                >
              </div>

              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Last Name</label>

                <input
                  type="text"
                  autocomplete="family-name"
                  value="Doe"
                  class="
                    w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                    dark:border-slate-600 dark:bg-slate-700 dark:text-white
                  "
                >
              </div>

              <div class="md:col-span-2">
                <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Bio</label>

                <textarea
                  rows="3"
                  class="
                    w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                    dark:border-slate-600 dark:bg-slate-700 dark:text-white
                  "
                >Software developer passionate about open source and accessibility.</textarea>
              </div>

              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Location</label>

                <input
                  type="text"
                  autocomplete="address-level2"
                  value="San Francisco, CA"
                  class="
                    w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                    dark:border-slate-600 dark:bg-slate-700 dark:text-white
                  "
                >
              </div>

              <div>
                <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Website</label>

                <input
                  type="url"
                  autocomplete="url"
                  value="https://johndoe.dev"
                  class="
                    w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                    dark:border-slate-600 dark:bg-slate-700 dark:text-white
                  "
                >
              </div>
            </div>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-account', tab_id: 'tab-account') do %>
          <div class="space-y-6 p-6">
            <div>
              <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Account Information</h3>

              <div class="space-y-4">
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Email Address</label>

                  <input
                    type="email"
                    autocomplete="email"
                    value="john.doe@example.com"
                    class="
                      w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                      dark:border-slate-600 dark:bg-slate-700 dark:text-white
                    "
                  >
                </div>

                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Username</label>

                  <input
                    type="text"
                    autocomplete="username"
                    value="johndoe"
                    class="
                      w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                      dark:border-slate-600 dark:bg-slate-700 dark:text-white
                    "
                  >
                </div>
              </div>
            </div>

            <div class="border-t border-slate-200 pt-6 dark:border-slate-600">
              <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Language & Region</h3>

              <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Language</label>

                  <select
                    class="
                      w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                      dark:border-slate-600 dark:bg-slate-700 dark:text-white
                    "
                  >
                    <option>English (US)</option>
                    <option>Español</option>
                    <option>Français</option>
                    <option>Deutsch</option>
                  </select>
                </div>

                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Timezone</label>

                  <select
                    class="
                      w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                      dark:border-slate-600 dark:bg-slate-700 dark:text-white
                    "
                  >
                    <option>Pacific Time (PT)</option>
                    <option>Mountain Time (MT)</option>
                    <option>Central Time (CT)</option>
                    <option>Eastern Time (ET)</option>
                  </select>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-security', tab_id: 'tab-security') do %>
          <div class="space-y-6 p-6">
            <div>
              <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Change Password</h3>

              <div class="space-y-4">
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">
                    Current Password
                  </label>

                  <input
                    type="password"
                    autocomplete="current-password"
                    class="
                      w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                      dark:border-slate-600 dark:bg-slate-700 dark:text-white
                    "
                  >
                </div>

                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">New Password</label>

                  <input
                    type="password"
                    autocomplete="new-password"
                    class="
                      w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                      dark:border-slate-600 dark:bg-slate-700 dark:text-white
                    "
                  >
                </div>

                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">
                    Confirm New Password
                  </label>

                  <input
                    type="password"
                    autocomplete="new-password"
                    class="
                      w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900
                      dark:border-slate-600 dark:bg-slate-700 dark:text-white
                    "
                  >
                </div>
              </div>
            </div>

            <div class="border-t border-slate-200 pt-6 dark:border-slate-600">
              <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Two-Factor Authentication</h3>

              <div
                class="
                  flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 p-4 dark:border-green-800
                  dark:bg-green-900/20
                "
              >
                <%= icon(:check_circle, color: :success) %>

                <div>
                  <div class="mb-1 font-semibold text-green-900 dark:text-green-100">Enabled</div>

                  <div class="mb-3 text-sm text-green-800 dark:text-green-200">
                    Two-factor authentication is currently enabled for your account.
                  </div>

                  <button
                    class="
                      rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700
                      transition-colors hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-700
                      dark:text-slate-300 dark:hover:bg-slate-600
                    "
                  >
                    Manage Settings
                  </button>
                </div>
              </div>
            </div>

            <div class="border-t border-slate-200 pt-6 dark:border-slate-600">
              <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Active Sessions</h3>

              <div class="space-y-3">
                <div
                  class="
                    flex items-center justify-between rounded-lg border border-slate-200 bg-slate-50 p-3
                    dark:border-slate-600 dark:bg-slate-700
                  "
                >
                  <div>
                    <div class="font-semibold text-slate-900 dark:text-white">Chrome on macOS</div>
                    <div class="text-sm text-slate-600 dark:text-slate-400">San Francisco, CA • Last active: Now</div>
                  </div>

                  <span
                    class="
                      rounded bg-green-100 px-2 py-1 text-xs font-medium text-green-800 dark:bg-green-900
                      dark:text-green-200
                    "
                  >
                    Current
                  </span>
                </div>

                <div
                  class="
                    flex items-center justify-between rounded-lg border border-slate-200 bg-slate-50 p-3
                    dark:border-slate-600 dark:bg-slate-700
                  "
                >
                  <div>
                    <div class="font-semibold text-slate-900 dark:text-white">Safari on iPhone</div>

                    <div class="text-sm text-slate-600 dark:text-slate-400">
                      San Francisco, CA • Last active: 2 hours ago
                    </div>
                  </div>

                  <button class="text-sm text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300">
                    Revoke
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-notifications', tab_id: 'tab-notifications') do %>
          <div class="space-y-6 p-6">
            <div>
              <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Email Notifications</h3>

              <div class="space-y-3">
                <% [
                  { label: 'Comments on your posts', description: 'Receive emails when someone comments on your content', checked: true },
                  { label: 'New followers', description: 'Get notified when someone follows your profile', checked: true },
                  { label: 'Direct messages', description: 'Email notifications for new direct messages', checked: false },
                  { label: 'Weekly digest', description: 'Summary of activity from the past week', checked: true }
                ].each do |setting| %>
                  <label
                    class="
                      flex cursor-pointer items-start gap-3 rounded-lg border border-slate-200 bg-slate-50 p-3
                      transition-colors hover:bg-slate-100 dark:border-slate-600 dark:bg-slate-700
                      dark:hover:bg-slate-600
                    "
                  >
                    <input
                      type="checkbox"
                      <%= 'checked' if setting[:checked] %>
                      class="mt-1 h-4 w-4 rounded text-blue-600"
                    >

                    <div>
                      <div class="font-medium text-slate-900 dark:text-white"><%= setting[:label] %></div>
                      <div class="text-sm text-slate-600 dark:text-slate-400"><%= setting[:description] %></div>
                    </div>
                  </label>
                <% end %>
              </div>
            </div>

            <div class="border-t border-slate-200 pt-6 dark:border-slate-600">
              <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Push Notifications</h3>

              <div
                class="
                  flex items-start gap-3 rounded-lg border border-amber-200 bg-amber-50 p-4 dark:border-amber-800
                  dark:bg-amber-900/20
                "
              >
                <%= icon(:bell_slash, color: :warning) %>

                <div>
                  <div class="mb-1 font-semibold text-amber-900 dark:text-amber-100">Not Enabled</div>

                  <div class="mb-3 text-sm text-amber-800 dark:text-amber-200">
                    Enable push notifications to get real-time updates on your device.
                  </div>

                  <button class="rounded-md bg-amber-600 px-3 py-1.5 text-sm text-white transition-colors hover:bg-amber-700">
                    Enable Push Notifications
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Data Dashboard Example -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:chart_bar_horizontal, color: :primary, class: "mr-3") %> Analytics Dashboard
    </h2>

    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <%= render(Pathogen::Tabs.new(
        id: 'dashboard-tabs',
        label: 'Analytics dashboard sections'
      )) do |tabs| %>
        <% tabs.with_tab(id: 'tab-overview', label: 'Overview', selected: true) %>
        <% tabs.with_tab(id: 'tab-traffic', label: 'Traffic') %>
        <% tabs.with_tab(id: 'tab-engagement', label: 'Engagement') %>
        <% tabs.with_tab(id: 'tab-conversions', label: 'Conversions') %>

        <% tabs.with_panel(id: 'panel-overview', tab_id: 'tab-overview') do %>
          <div class="p-6">
            <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-4">
              <% [
                { label: 'Total Visitors', value: '124,582', change: '+12.5%', trend: :up },
                { label: 'Page Views', value: '456,789', change: '+8.2%', trend: :up },
                { label: 'Avg. Duration', value: '4m 32s', change: '-2.1%', trend: :down },
                { label: 'Bounce Rate', value: '42.3%', change: '-5.4%', trend: :up }
              ].each do |metric| %>
                <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-slate-600 dark:bg-slate-700">
                  <div class="mb-1 text-sm text-slate-600 dark:text-slate-400"><%= metric[:label] %></div>
                  <div class="mb-1 text-2xl font-bold text-slate-900 dark:text-white"><%= metric[:value] %></div>

                  <div class="flex items-center gap-1 text-sm <%= metric[:trend] == :up ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                    <%= icon(metric[:trend] == :up ? :trending_up : :trending_down, size: :sm, color: metric[:trend] == :up ? :success : :danger) %>
                    <span><%= metric[:change] %></span>
                  </div>
                </div>
              <% end %>
            </div>

            <div
              class="
                flex h-64 items-center justify-center rounded-lg border border-slate-200 bg-slate-50
                dark:border-slate-600 dark:bg-slate-700
              "
            >
              <div class="text-center text-slate-600 dark:text-slate-400">
                <%= icon(:chart_line_up, color: :primary, size: :xl) %>

                <p class="mt-2">Traffic Chart Visualization</p>
              </div>
            </div>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-traffic', tab_id: 'tab-traffic') do %>
          <div class="p-6">
            <h3 class="mb-4 text-xl font-semibold text-slate-900 dark:text-white">Traffic Sources</h3>

            <div class="space-y-3">
              <% [
                { source: 'Organic Search', visitors: '45,234', percentage: 36 },
                { source: 'Direct', visitors: '32,156', percentage: 26 },
                { source: 'Social Media', visitors: '28,912', percentage: 23 },
                { source: 'Referral', visitors: '18,280', percentage: 15 }
              ].each do |source| %>
                <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-slate-600 dark:bg-slate-700">
                  <div class="mb-2 flex items-center justify-between">
                    <span class="font-semibold text-slate-900 dark:text-white"><%= source[:source] %></span>
                    <span class="text-slate-600 dark:text-slate-400"><%= source[:visitors] %> visitors</span>
                  </div>

                  <div class="h-2 w-full rounded-full bg-slate-200 dark:bg-slate-600">
                    <div class="h-2 rounded-full bg-blue-600" style="width: <%= source[:percentage] %>%"></div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-engagement', tab_id: 'tab-engagement') do %>
          <div class="p-6">
            <h3 class="mb-4 text-xl font-semibold text-slate-900 dark:text-white">User Engagement</h3>

            <p class="text-slate-600 dark:text-slate-400">
              Engagement metrics and user interaction data would be displayed here.
            </p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-conversions', tab_id: 'tab-conversions') do %>
          <div class="p-6">
            <h3 class="mb-4 text-xl font-semibold text-slate-900 dark:text-white">Conversion Tracking</h3>

            <p class="text-slate-600 dark:text-slate-400">
              Conversion funnel and goal tracking would be displayed here.
            </p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Documentation Navigation Example -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:file_text, color: :primary, class: "mr-3") %> Documentation Navigation
    </h2>

    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <%= render(Pathogen::Tabs.new(
        id: 'docs-tabs',
        label: 'Documentation sections',
        orientation: :vertical,
        sync_url: true
      )) do |tabs| %>
        <% tabs.with_tab(id: 'tab-getting-started', label: 'Getting Started', selected: true) %>
        <% tabs.with_tab(id: 'tab-installation', label: 'Installation') %>
        <% tabs.with_tab(id: 'tab-configuration', label: 'Configuration') %>
        <% tabs.with_tab(id: 'tab-api-reference', label: 'API Reference') %>
        <% tabs.with_tab(id: 'tab-examples', label: 'Examples') %>
        <% tabs.with_tab(id: 'tab-troubleshooting', label: 'Troubleshooting') %>

        <% tabs.with_panel(id: 'panel-getting-started', tab_id: 'tab-getting-started') do %>
          <div class="prose dark:prose-invert max-w-none p-6">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">Getting Started</h3>

            <p class="text-slate-700 dark:text-slate-300">
              Welcome to the documentation! This guide will help you get up and running quickly with our platform.
            </p>

            <div class="mt-4 rounded-lg border border-blue-200 bg-blue-50 p-4 dark:border-blue-800 dark:bg-blue-900/20">
              <div class="flex items-start gap-3">
                <%= icon(:lightbulb, color: :primary) %>

                <div class="text-sm text-blue-800 dark:text-blue-200">
                  <strong>Tip:</strong> Use the vertical navigation on the left to explore different sections. The URL
                  will update so you can bookmark specific pages.
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-installation', tab_id: 'tab-installation') do %>
          <div class="space-y-4 p-6">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">Installation</h3>
            <p class="text-slate-700 dark:text-slate-300">Install the package using your preferred package manager:</p>

            <div
              class="
                overflow-x-auto rounded-lg border border-slate-200 bg-slate-50 p-4 shadow-sm dark:border-slate-700
                dark:bg-slate-900
              "
            >
              <pre class="text-sm"><code class="text-slate-800 dark:text-slate-200"># Using npm npm install @pathogen/tabs # Using yarn yarn add @pathogen/tabs # Using pnpm pnpm add @pathogen/tabs              </code></pre>
            </div>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-configuration', tab_id: 'tab-configuration') do %>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-slate-900 dark:text-white">Configuration</h3>

            <p class="text-slate-700 dark:text-slate-300">
              Configuration options and setup instructions would go here.
            </p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-api-reference', tab_id: 'tab-api-reference') do %>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-slate-900 dark:text-white">API Reference</h3>

            <p class="text-slate-700 dark:text-slate-300">
              Complete API documentation and method references would go here.
            </p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-examples', tab_id: 'tab-examples') do %>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-slate-900 dark:text-white">Examples</h3>
            <p class="text-slate-700 dark:text-slate-300">Code examples and usage patterns would go here.</p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'panel-troubleshooting', tab_id: 'tab-troubleshooting') do %>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-slate-900 dark:text-white">Troubleshooting</h3>
            <p class="text-slate-700 dark:text-slate-300">Common issues and solutions would go here.</p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Best Practices -->
  <div>
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:lightbulb, color: :warning, class: "mr-3") %> Integration Best Practices
    </h2>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:check_circle, color: :success, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Do: Organize by Purpose</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              Group related content together logically. Profile settings, account settings, and security settings make
              sense as separate tabs.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:check_circle, color: :success, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Do: Use URL Sync for Navigation</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              Enable <code class="rounded bg-slate-100 px-1 dark:bg-slate-700">sync_url</code> for pages where users
              might want to bookmark or share specific tabs.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:check_circle, color: :success, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Do: Lazy Load Heavy Content</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              Use Turbo Frames with <code class="rounded bg-slate-100 px-1 dark:bg-slate-700">loading: :lazy</code> for
              tabs with expensive queries or large data sets.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:check_circle, color: :success, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Do: Add Contextual Actions</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              Use the <code class="rounded bg-slate-100 px-1 dark:bg-slate-700">right_content</code> slot for actions
              relevant to the entire tab group, like Save or Export.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:x, color: :danger, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Don't: Nest Tabs Too Deeply</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              Avoid putting tabs inside tabs. This creates confusing navigation and accessibility issues. Use a
              different organizational pattern instead.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:x, color: :danger, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Don't: Use Too Many Tabs</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              More than 7-8 tabs becomes overwhelming. Consider using vertical tabs, a sidebar navigation, or a
              different organizational structure.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:x, color: :danger, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Don't: Use for Sequential Steps</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              For multi-step forms with enforced order, use a stepper component instead. Tabs suggest users can jump
              freely between sections.
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="mb-4 flex items-start gap-3">
          <%= icon(:x, color: :danger, size: :lg) %>

          <div>
            <h3 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Don't: Hide Critical Info</h3>

            <p class="text-sm text-slate-600 dark:text-slate-400">
              Don't hide essential information in non-default tabs. Users may not discover it. Make important content
              visible or provide clear indicators.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
