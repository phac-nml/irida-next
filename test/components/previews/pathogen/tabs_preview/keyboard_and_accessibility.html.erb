<div class="min-h-screen bg-gradient-to-br from-indigo-50 to-purple-50 p-8 dark:from-slate-900 dark:to-indigo-950">
  <!-- Header -->
  <div class="mb-12 text-center">
    <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-slate-100">
      <%= icon(:keyboard, color: :primary, size: :xl, class: "inline mr-3") %> Keyboard Navigation & Accessibility
    </h1>

    <p class="mx-auto max-w-3xl text-lg text-slate-600 dark:text-slate-400">
      Full W3C ARIA pattern implementation with comprehensive keyboard support and screen reader accessibility.
    </p>
  </div>

  <!-- Interactive Keyboard Demo -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:hand_pointing, color: :primary, class: "mr-3") %> Interactive Keyboard Demo
    </h2>

    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <div class="border-b border-slate-200 bg-slate-50 p-6 dark:border-slate-600 dark:bg-slate-700">
        <p class="mb-3 flex items-center gap-2 text-slate-700 dark:text-slate-300">
          <%= icon(:info, color: :primary) %> <strong>Try it:</strong> Click a tab, then use arrow keys to navigate.
          Notice automatic activation!
        </p>

        <div class="flex flex-wrap gap-2">
          <kbd
            class="
              rounded border border-slate-300 bg-white px-3 py-1 font-mono text-sm shadow-sm dark:border-slate-600
              dark:bg-slate-800
            "
          >
            ←
          </kbd>

          <kbd
            class="
              rounded border border-slate-300 bg-white px-3 py-1 font-mono text-sm shadow-sm dark:border-slate-600
              dark:bg-slate-800
            "
          >
            →
          </kbd>

          <kbd
            class="
              rounded border border-slate-300 bg-white px-3 py-1 font-mono text-sm shadow-sm dark:border-slate-600
              dark:bg-slate-800
            "
          >
            Home
          </kbd>

          <kbd
            class="
              rounded border border-slate-300 bg-white px-3 py-1 font-mono text-sm shadow-sm dark:border-slate-600
              dark:bg-slate-800
            "
          >
            End
          </kbd>

          <kbd
            class="
              rounded border border-slate-300 bg-white px-3 py-1 font-mono text-sm shadow-sm dark:border-slate-600
              dark:bg-slate-800
            "
          >
            Tab
          </kbd>
        </div>
      </div>

      <%= render(Pathogen::Tabs.new(id: 'keyboard-demo-tabs', label: 'Keyboard navigation demonstration')) do |tabs| %>
        <% tabs.with_tab(id: 'kbd-tab-1', label: 'Tab 1', selected: true) %>
        <% tabs.with_tab(id: 'kbd-tab-2', label: 'Tab 2') %>
        <% tabs.with_tab(id: 'kbd-tab-3', label: 'Tab 3') %>
        <% tabs.with_tab(id: 'kbd-tab-4', label: 'Tab 4') %>
        <% tabs.with_tab(id: 'kbd-tab-5', label: 'Tab 5') %>

        <% tabs.with_panel(id: 'kbd-panel-1', tab_id: 'kbd-tab-1') do %>
          <div class="p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-900 dark:text-white">Arrow Key Navigation</h3>

            <p class="text-slate-700 dark:text-slate-300">
              Press the
              <kbd class="
                rounded border border-slate-300 bg-slate-100 px-2 py-0.5 text-sm dark:border-slate-600
                dark:bg-slate-700
              ">→</kbd>
              key to move to the next tab. The tab will activate automatically without needing to press Enter.
            </p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'kbd-panel-2', tab_id: 'kbd-tab-2') do %>
          <div class="p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-900 dark:text-white">Automatic Activation</h3>

            <p class="text-slate-700 dark:text-slate-300">
              Notice how this panel appeared immediately when you pressed the arrow key? This is called "automatic
              activation" and provides a faster, more fluid experience than manual activation (which requires
              Enter/Space).
            </p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'kbd-panel-3', tab_id: 'kbd-tab-3') do %>
          <div class="p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-900 dark:text-white">Wrapping Behavior</h3>

            <p class="text-slate-700 dark:text-slate-300">
              Keep pressing
              <kbd class="
                rounded border border-slate-300 bg-slate-100 px-2 py-0.5 text-sm dark:border-slate-600
                dark:bg-slate-700
              ">→</kbd>
              until you reach the last tab, then press it once more. The focus wraps around to the first tab!
            </p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'kbd-panel-4', tab_id: 'kbd-tab-4') do %>
          <div class="p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-900 dark:text-white">Jump Navigation</h3>

            <p class="text-slate-700 dark:text-slate-300">
              Try pressing
              <kbd class="
                rounded border border-slate-300 bg-slate-100 px-2 py-0.5 text-sm dark:border-slate-600
                dark:bg-slate-700
              ">Home</kbd>
              to jump to the first tab, or
              <kbd class="
                rounded border border-slate-300 bg-slate-100 px-2 py-0.5 text-sm dark:border-slate-600
                dark:bg-slate-700
              ">End</kbd>
              to jump to the last tab instantly.
            </p>
          </div>
        <% end %>

        <% tabs.with_panel(id: 'kbd-panel-5', tab_id: 'kbd-tab-5') do %>
          <div class="p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-900 dark:text-white">Tab Key Behavior</h3>

            <p class="mb-3 text-slate-700 dark:text-slate-300">
              Press
              <kbd class="
                rounded border border-slate-300 bg-slate-100 px-2 py-0.5 text-sm dark:border-slate-600
                dark:bg-slate-700
              ">Tab</kbd>
              to move focus OUT of the tab list and into the panel content below. This button should receive focus:
            </p>

            <button class="rounded-lg bg-primary-600 px-4 py-2 text-white hover:bg-primary-700">
              Focusable button in panel
            </button>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- ARIA Attributes Reference -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:code, color: :primary, class: "mr-3") %> ARIA Attributes
    </h2>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      <!-- Tablist Attributes -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-slate-900 dark:text-white">
          <%= icon(:list, color: :primary) %> Tablist Attributes
        </h3>

        <div class="space-y-3 text-sm">
          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">role="tablist"</code>
            <span class="text-slate-600 dark:text-slate-400">Identifies the container as a tab list</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">aria-label</code>
            <span class="text-slate-600 dark:text-slate-400">Provides accessible name for screen readers</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">aria-orientation</code>
            <span class="text-slate-600 dark:text-slate-400">Indicates horizontal or vertical layout</span>
          </div>
        </div>
      </div>

      <!-- Tab Attributes -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-slate-900 dark:text-white">
          <%= icon(:square, color: :primary) %> Tab Button Attributes
        </h3>

        <div class="space-y-3 text-sm">
          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">role="tab"</code>
            <span class="text-slate-600 dark:text-slate-400">Identifies each button as a tab</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">aria-selected</code>
            <span class="text-slate-600 dark:text-slate-400">true for active tab, false for others</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">aria-controls</code>
            <span class="text-slate-600 dark:text-slate-400">References the panel ID this tab controls</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">tabindex</code>
            <span class="text-slate-600 dark:text-slate-400">0 for active tab, -1 for others (roving tabindex)</span>
          </div>
        </div>
      </div>

      <!-- Panel Attributes -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-slate-900 dark:text-white">
          <%= icon(:sidebar, color: :primary) %> Panel Attributes
        </h3>

        <div class="space-y-3 text-sm">
          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">role="tabpanel"</code>
            <span class="text-slate-600 dark:text-slate-400">Identifies the content panel</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">aria-labelledby</code>
            <span class="text-slate-600 dark:text-slate-400">References the tab ID that controls this panel</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">aria-hidden</code>
            <span class="text-slate-600 dark:text-slate-400">true when hidden, false when visible</span>
          </div>

          <div class="flex items-start gap-3 rounded bg-slate-50 p-3 dark:bg-slate-700">
            <code class="flex-shrink-0 font-mono text-blue-600 dark:text-blue-400">tabindex="0"</code>
            <span class="text-slate-600 dark:text-slate-400">Makes panel focusable for screen readers</span>
          </div>
        </div>
      </div>

      <!-- Roving Tabindex Pattern -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-slate-900 dark:text-white">
          <%= icon(:arrows_left_right, color: :primary) %> Roving Tabindex Pattern
        </h3>

        <div class="space-y-3 text-sm text-slate-600 dark:text-slate-400">
          <p>
            The component implements the roving tabindex pattern for optimal keyboard navigation:
          </p>

          <ul class="list-inside list-disc space-y-2 pl-3">
            <li>
              Only the active tab has <code class="rounded bg-slate-100 px-1 dark:bg-slate-700">tabindex="0"</code>
            </li>

            <li>
              All inactive tabs have <code class="rounded bg-slate-100 px-1 dark:bg-slate-700">tabindex="-1"</code>
            </li>

            <li>This ensures only one tab is in the Tab key sequence</li>
            <li>Arrow keys move focus and update tabindex dynamically</li>
          </ul>

          <div class="mt-4 rounded border border-green-200 bg-green-50 p-3 dark:border-green-800 dark:bg-green-900/20">
            <strong class="text-green-900 dark:text-green-100">Why?</strong>

            <span class="text-green-800 dark:text-green-200">
              This prevents Tab key from stopping on every inactive tab, providing a better user experience.
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Screen Reader Experience -->
  <div>
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:speaker_high, color: :primary, class: "mr-3") %> Screen Reader Experience
    </h2>

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <div class="prose dark:prose-invert max-w-none">
        <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">What Screen Readers Announce</h3>

        <div class="space-y-4">
          <div class="flex items-start gap-4 rounded-lg bg-slate-50 p-4 dark:bg-slate-700">
            <div
              class="
                flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-blue-100 font-semibold
                text-blue-600 dark:bg-blue-900 dark:text-blue-300
              "
            >
              1
            </div>

            <div>
              <div class="mb-1 font-semibold text-slate-900 dark:text-white">Entering the Tab List</div>

              <div class="text-sm text-slate-600 italic dark:text-slate-400">
                "Content sections, tab list" <span class="text-xs">(from aria-label)</span>
              </div>
            </div>
          </div>

          <div class="flex items-start gap-4 rounded-lg bg-slate-50 p-4 dark:bg-slate-700">
            <div
              class="
                flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-blue-100 font-semibold
                text-blue-600 dark:bg-blue-900 dark:text-blue-300
              "
            >
              2
            </div>

            <div>
              <div class="mb-1 font-semibold text-slate-900 dark:text-white">On Each Tab</div>

              <div class="text-sm text-slate-600 italic dark:text-slate-400">
                "Overview, tab, selected, 1 of 3" <span class="text-xs">(tab label, role, state, position)</span>
              </div>
            </div>
          </div>

          <div class="flex items-start gap-4 rounded-lg bg-slate-50 p-4 dark:bg-slate-700">
            <div
              class="
                flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-blue-100 font-semibold
                text-blue-600 dark:bg-blue-900 dark:text-blue-300
              "
            >
              3
            </div>

            <div>
              <div class="mb-1 font-semibold text-slate-900 dark:text-white">Entering Panel Content</div>

              <div class="text-sm text-slate-600 italic dark:text-slate-400">
                "Overview panel content, tab panel" <span class="text-xs">(from aria-labelledby)</span>
              </div>
            </div>
          </div>

          <div class="flex items-start gap-4 rounded-lg bg-slate-50 p-4 dark:bg-slate-700">
            <div
              class="
                flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-blue-100 font-semibold
                text-blue-600 dark:bg-blue-900 dark:text-blue-300
              "
            >
              4
            </div>

            <div>
              <div class="mb-1 font-semibold text-slate-900 dark:text-white">Switching Tabs</div>

              <div class="text-sm text-slate-600 italic dark:text-slate-400">
                "Features, tab, selected" <span class="text-xs">(new tab announces immediately)</span>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-6 rounded-lg border border-purple-200 bg-purple-50 p-4 dark:border-purple-800 dark:bg-purple-900/20">
          <div class="flex items-start gap-3">
            <%= icon(:info, color: :primary) %>

            <div class="text-sm">
              <strong class="text-purple-900 dark:text-purple-100">Testing Tip:</strong>

              <span class="text-purple-800 dark:text-purple-200">
                Test with NVDA (Windows), JAWS (Windows), or VoiceOver (Mac) to verify the experience yourself. The
                component follows W3C patterns to ensure consistent behavior across screen readers.
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
