<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 p-8 dark:from-slate-900 dark:to-slate-800">
  <!-- Header -->
  <div class="mb-12 text-center">
    <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-slate-100">
      <%= icon(:info, color: :primary, size: :xl, class: "inline mr-3") %> Pathogen Tooltip - Basic Usage
    </h1>

    <p class="mx-auto max-w-3xl text-lg text-slate-600 dark:text-slate-400">
      Accessible tooltips with JavaScript positioning, smooth animations, and Primer-inspired design.
    </p>
  </div>

  <!-- Four Placement Options -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:compass, color: :primary, class: "mr-3") %> Four Placement Options
    </h2>

    <div class="rounded-xl border border-slate-200 bg-white p-12 shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <div class="flex flex-col items-center justify-center space-y-24">
        <!-- Top Placement -->
        <div class="text-center">
          <p class="mb-4 text-sm text-slate-500 dark:text-slate-400">Top Placement (Default)</p>

          <%= render Pathogen::Link.new(href: "#") do |link| %>
            <% link.with_tooltip(text: "This tooltip appears above the link", placement: :top) %> Hover or focus me
            (top)
          <% end %>
        </div>

        <div class="flex items-center justify-center space-x-48">
          <!-- Left Placement -->
          <div class="text-center">
            <p class="mb-4 text-sm text-slate-500 dark:text-slate-400">Left Placement</p>

            <%= render Pathogen::Link.new(href: "#") do |link| %>
              <% link.with_tooltip(text: "This tooltip appears to the left", placement: :left) %> Hover or focus me
              (left)
            <% end %>
          </div>

          <!-- Right Placement -->
          <div class="text-center">
            <p class="mb-4 text-sm text-slate-500 dark:text-slate-400">Right Placement</p>

            <%= render Pathogen::Link.new(href: "#") do |link| %>
              <% link.with_tooltip(text: "This tooltip appears to the right", placement: :right) %> Hover or focus me
              (right)
            <% end %>
          </div>
        </div>

        <!-- Bottom Placement -->
        <div class="text-center">
          <p class="mb-4 text-sm text-slate-500 dark:text-slate-400">Bottom Placement</p>

          <%= render Pathogen::Link.new(href: "#") do |link| %>
            <% link.with_tooltip(
              text: "This tooltip appears below the link",
              placement: :bottom,
            ) %>
            Hover or focus me (bottom)
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Simple Examples -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:code, color: :primary, class: "mr-3") %> Simple Examples
    </h2>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <!-- Example 1: Default Tooltip -->
      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-100">Default Tooltip</h3>

        <div class="rounded bg-slate-50 p-4 dark:bg-slate-900">
          <%= render Pathogen::Link.new(href: "/samples") do |link| %>
            <% link.with_tooltip(text: "View all samples") %> Samples
          <% end %>
        </div>
      </div>

      <!-- Example 2: Bottom Placement -->
      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-100">Custom Placement</h3>

        <div class="rounded bg-slate-50 p-4 dark:bg-slate-900">
          <%= render Pathogen::Link.new(href: "/projects") do |link| %>
            <% link.with_tooltip(text: "Manage your projects", placement: :bottom) %> Projects
          <% end %>
        </div>
      </div>

      <!-- Example 3: Left Placement -->
      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-100">Left Placement</h3>

        <div class="rounded bg-slate-50 p-4 dark:bg-slate-900">
          <%= render Pathogen::Link.new(href: "/settings") do |link| %>
            <% link.with_tooltip(text: "Configure application settings", placement: :left) %> Settings
          <% end %>
        </div>
      </div>

      <!-- Example 4: Right Placement -->
      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-100">Right Placement</h3>

        <div class="rounded bg-slate-50 p-4 dark:bg-slate-900">
          <%= render Pathogen::Link.new(href: "/help") do |link| %>
            <% link.with_tooltip(text: "Get help and documentation", placement: :right) %> Help
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Parameter Reference -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:sliders, color: :primary, class: "mr-3") %> Component Parameters
    </h2>

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-700">
              <th class="px-4 py-3 font-semibold text-slate-900 dark:text-slate-100">Parameter</th>
              <th class="px-4 py-3 font-semibold text-slate-900 dark:text-slate-100">Type</th>
              <th class="px-4 py-3 font-semibold text-slate-900 dark:text-slate-100">Required</th>
              <th class="px-4 py-3 font-semibold text-slate-900 dark:text-slate-100">Description</th>
            </tr>
          </thead>

          <tbody class="text-sm">
            <tr class="border-b border-slate-100 dark:border-slate-700">
              <td class="px-4 py-3 font-mono text-blue-600 dark:text-blue-400">text</td>
              <td class="px-4 py-3 text-slate-600 dark:text-slate-400">String</td>

              <td class="px-4 py-3">
                <span class="rounded bg-red-100 px-2 py-1 text-xs text-red-800 dark:bg-red-900 dark:text-red-200">
                  Required
                </span>
              </td>

              <td class="px-4 py-3 text-slate-600 dark:text-slate-400">The tooltip text content</td>
            </tr>

            <tr class="border-b border-slate-100 dark:border-slate-700">
              <td class="px-4 py-3 font-mono text-blue-600 dark:text-blue-400">placement</td>
              <td class="px-4 py-3 text-slate-600 dark:text-slate-400">Symbol</td>

              <td class="px-4 py-3">
                <span class="rounded bg-slate-100 px-2 py-1 text-xs text-slate-600 dark:bg-slate-700 dark:text-slate-400">
                  Optional
                </span>
              </td>

              <td class="px-4 py-3 text-slate-600 dark:text-slate-400">
                Position: :top (default), :bottom, :left, :right
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Quick Tips -->
  <div>
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:lightbulb, color: :warning, class: "mr-3") %> Quick Tips
    </h2>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-blue-200 bg-blue-50 p-4 dark:border-blue-800 dark:bg-blue-900/20">
        <div class="flex items-start gap-3">
          <%= icon(:info, color: :primary) %>

          <div>
            <h3 class="mb-1 font-semibold text-blue-900 dark:text-blue-100">Default Placement is Top</h3>

            <p class="text-sm text-blue-800 dark:text-blue-200">
              If you don't specify a placement, tooltips will appear above the trigger element
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-green-200 bg-green-50 p-4 dark:border-green-800 dark:bg-green-900/20">
        <div class="flex items-start gap-3">
          <%= icon(:check_circle, color: :success) %>

          <div>
            <h3 class="mb-1 font-semibold text-green-900 dark:text-green-100">Automatic Sizing</h3>

            <p class="text-sm text-green-800 dark:text-green-200">
              Tooltips automatically size to fit content with a max width of 320px
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-purple-200 bg-purple-50 p-4 dark:border-purple-800 dark:bg-purple-900/20">
        <div class="flex items-start gap-3">
          <%= icon(:lightning, color: :primary) %>

          <div>
            <h3 class="mb-1 font-semibold text-purple-900 dark:text-purple-100">Smooth Animations</h3>

            <p class="text-sm text-purple-800 dark:text-purple-200">
              200ms fade-in and scale animation for a polished feel
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 dark:border-amber-800 dark:bg-amber-900/20">
        <div class="flex items-start gap-3">
          <%= icon(:warning, color: :warning) %>

          <div>
            <h3 class="mb-1 font-semibold text-amber-900 dark:text-amber-100">Lightweight Dependencies</h3>

            <p class="text-sm text-amber-800 dark:text-amber-200">
              Uses Floating UI for precise positioning instead of Flowbite/Popper.js
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
