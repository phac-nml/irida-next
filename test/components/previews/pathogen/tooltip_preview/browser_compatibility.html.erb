<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 p-8 dark:from-slate-900 dark:to-slate-800">
  <!-- Header -->
  <div class="mb-12 text-center">
    <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-slate-100">
      <%= icon(:globe, color: :primary, size: :xl, class: "inline mr-3") %> Browser Compatibility
    </h1>

    <p class="mx-auto max-w-3xl text-lg text-slate-600 dark:text-slate-400">
      JavaScript positioning with viewport detection for broad browser compatibility
    </p>
  </div>

  <!-- Browser Support Status -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:check_circle, color: :success, class: "mr-3") %> Universal Browser Compatibility
    </h2>

    <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <p class="mb-6 text-slate-600 dark:text-slate-400">
        This tooltip component uses JavaScript-based positioning for maximum browser compatibility. Works in all modern
        browsers with ES6+ JavaScript support:
      </p>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div
          class="
            flex items-center rounded-lg border border-green-200 bg-green-50 p-3 dark:border-green-800
            dark:bg-green-900/20
          "
        >
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded bg-green-100 dark:bg-green-900/30">
              <%= icon(:check, color: :success) %>
            </div>

            <div>
              <div class="font-semibold text-green-900 dark:text-green-100">Chrome</div>
              <div class="text-sm text-green-800 dark:text-green-200">Modern versions</div>
            </div>
          </div>
        </div>

        <div
          class="
            flex items-center rounded-lg border border-green-200 bg-green-50 p-3 dark:border-green-800
            dark:bg-green-900/20
          "
        >
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded bg-green-100 dark:bg-green-900/30">
              <%= icon(:check, color: :success) %>
            </div>

            <div>
              <div class="font-semibold text-green-900 dark:text-green-100">Firefox</div>
              <div class="text-sm text-green-800 dark:text-green-200">Modern versions</div>
            </div>
          </div>
        </div>

        <div
          class="
            flex items-center rounded-lg border border-green-200 bg-green-50 p-3 dark:border-green-800
            dark:bg-green-900/20
          "
        >
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded bg-green-100 dark:bg-green-900/30">
              <%= icon(:check, color: :success) %>
            </div>

            <div>
              <div class="font-semibold text-green-900 dark:text-green-100">Safari</div>
              <div class="text-sm text-green-800 dark:text-green-200">Modern versions</div>
            </div>
          </div>
        </div>

        <div
          class="
            flex items-center rounded-lg border border-green-200 bg-green-50 p-3 dark:border-green-800
            dark:bg-green-900/20
          "
        >
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded bg-green-100 dark:bg-green-900/30">
              <%= icon(:check, color: :success) %>
            </div>

            <div>
              <div class="font-semibold text-green-900 dark:text-green-100">Edge</div>
              <div class="text-sm text-green-800 dark:text-green-200">Modern versions</div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 rounded-lg border border-blue-200 bg-blue-50 p-4 dark:border-blue-800 dark:bg-blue-900/20">
        <div class="flex items-start gap-3">
          <%= icon(:info, color: :primary) %>

          <div class="text-sm">
            <p class="mb-1 font-semibold text-blue-900 dark:text-blue-100">JavaScript Positioning</p>

            <p class="text-blue-800 dark:text-blue-200">
              The tooltip uses JavaScript-based positioning with `getBoundingClientRect()` for precise placement. This
              approach provides sophisticated features like viewport boundary detection and automatic placement flipping
              that work consistently across all modern browsers.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Positioning Strategy -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:shield, color: :success, class: "mr-3") %> Positioning Strategy
    </h2>

    <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <p class="mb-6 text-slate-600 dark:text-slate-400">
        The tooltip component uses JavaScript-based positioning with sophisticated viewport detection:
      </p>

      <div class="space-y-6">
        <!-- getBoundingClientRect Calculation -->
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-900/30">
            <%= icon(:code, color: :primary) %>
          </div>

          <div class="flex-1">
            <h3 class="mb-2 font-semibold text-slate-900 dark:text-slate-100">Precise Position Calculation</h3>

            <p class="mb-3 text-slate-600 dark:text-slate-400">
              Tooltips calculate their optimal position using `getBoundingClientRect()` to get exact trigger element
              coordinates, then apply calculated positions via inline styles.
            </p>

            <div class="rounded border border-slate-200 bg-slate-50 p-3 text-sm dark:border-slate-700 dark:bg-slate-900">
              <code class="text-slate-800 dark:text-slate-200">position: fixed; top: ${top}px; left: ${left}px;</code>
            </div>
          </div>
        </div>

        <!-- Viewport Boundary Detection -->
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-green-100 dark:bg-green-900/30">
            <%= icon(:arrows_in, color: :success) %>
          </div>

          <div class="flex-1">
            <h3 class="mb-2 font-semibold text-slate-900 dark:text-slate-100">Automatic Viewport Detection</h3>

            <p class="text-slate-600 dark:text-slate-400">
              The Stimulus controller detects when tooltips would overflow viewport edges and automatically flips
              placement:
            </p>

            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400">
              <li class="flex items-center gap-2">
                <%= icon(:check, color: :success, class: "flex-shrink-0") %> Top placement flips to bottom when near
                top edge
              </li>

              <li class="flex items-center gap-2">
                <%= icon(:check, color: :success, class: "flex-shrink-0") %> Bottom placement flips to top when near
                bottom edge
              </li>

              <li class="flex items-center gap-2">
                <%= icon(:check, color: :success, class: "flex-shrink-0") %> Left/right placements flip when near
                corresponding edges
              </li>

              <li class="flex items-center gap-2">
                <%= icon(:check, color: :success, class: "flex-shrink-0") %> Maintains 8px padding from viewport
                boundaries
              </li>
            </ul>
          </div>
        </div>

        <!-- Position Clamping -->
        <div class="flex items-start gap-4">
          <div
            class="
              flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-purple-100
              dark:bg-purple-900/30
            "
          >
            <%= icon(:lock, color: :primary) %>
          </div>

          <div class="flex-1">
            <h3 class="mb-2 font-semibold text-slate-900 dark:text-slate-100">Position Clamping</h3>

            <p class="text-slate-600 dark:text-slate-400">
              If a tooltip can't fit in its preferred placement even after flipping, the positioning algorithm clamps it
              to viewport bounds to ensure it remains fully visible with proper padding.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Why JavaScript Positioning? -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:lightbulb, color: :warning, class: "mr-3") %> Why JavaScript Positioning?
    </h2>

    <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <p class="mb-6 text-slate-600 dark:text-slate-400">
        The decision to use custom JavaScript positioning instead of external libraries or cutting-edge CSS features
        brings several advantages:
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="rounded-lg border border-green-200 bg-green-50 p-4 dark:border-green-800 dark:bg-green-900/20">
          <div class="flex items-start gap-3">
            <%= icon(:globe, color: :success, class: "flex-shrink-0") %>

            <div>
              <h3 class="mb-1 font-semibold text-green-900 dark:text-green-100">Broad Browser Compatibility</h3>

              <p class="text-sm text-green-800 dark:text-green-200">
                Works in all modern browsers (Chrome, Firefox, Safari, Edge) without feature flags or polyfills.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-blue-200 bg-blue-50 p-4 dark:border-blue-800 dark:bg-blue-900/20">
          <div class="flex items-start gap-3">
            <%= icon(:download, color: :primary, class: "flex-shrink-0") %>

            <div>
              <h3 class="mb-1 font-semibold text-blue-900 dark:text-blue-100">Smaller Bundle Size</h3>

              <p class="text-sm text-blue-800 dark:text-blue-200">
                No need to include Popper.js, Floating UI, or other positioning libraries, reducing JavaScript payload.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-purple-200 bg-purple-50 p-4 dark:border-purple-800 dark:bg-purple-900/20">
          <div class="flex items-start gap-3">
            <%= icon(:arrows_in, color: :primary, class: "flex-shrink-0") %>

            <div>
              <h3 class="mb-1 font-semibold text-purple-900 dark:text-purple-100">Sophisticated Viewport Detection</h3>

              <p class="text-sm text-purple-800 dark:text-purple-200">
                Automatic placement flipping and position clamping ensure tooltips always stay within viewport bounds.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 dark:border-amber-800 dark:bg-amber-900/20">
          <div class="flex items-start gap-3">
            <%= icon(:code, color: :warning, class: "flex-shrink-0") %>

            <div>
              <h3 class="mb-1 font-semibold text-amber-900 dark:text-amber-100">Full Control</h3>

              <p class="text-sm text-amber-800 dark:text-amber-200">
                Custom implementation allows precise control over positioning logic and edge cases.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-indigo-200 bg-indigo-50 p-4 dark:border-indigo-800 dark:bg-indigo-900/20">
          <div class="flex items-start gap-3">
            <%= icon(:puzzle_piece, color: :primary, class: "flex-shrink-0") %>

            <div>
              <h3 class="mb-1 font-semibold text-indigo-900 dark:text-indigo-100">Lightweight Dependencies</h3>

              <p class="text-sm text-indigo-800 dark:text-indigo-200">
                Uses Floating UI instead of Flowbite, reducing maintenance burden and improving positioning accuracy.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-teal-200 bg-teal-50 p-4 dark:border-teal-800 dark:bg-teal-900/20">
          <div class="flex items-start gap-3">
            <%= icon(:shield, color: :primary, class: "flex-shrink-0") %>

            <div>
              <h3 class="mb-1 font-semibold text-teal-900 dark:text-teal-100">Reliable & Predictable</h3>

              <p class="text-sm text-teal-800 dark:text-teal-200">
                JavaScript positioning provides consistent behavior across all browsers without browser-specific quirks.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Migration from Flowbite -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:arrows_clockwise, color: :primary, class: "mr-3") %> Migration from Flowbite
    </h2>

    <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-lg dark:border-slate-700 dark:bg-slate-800">
      <p class="mb-6 text-slate-600 dark:text-slate-400">
        This tooltip component was redesigned to remove the Flowbite dependency, which used Popper.js for positioning.
      </p>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <!-- Before: Flowbite -->
        <div>
          <h3 class="mb-4 flex items-center text-lg font-semibold text-slate-900 dark:text-slate-100">
            <%= icon(:x, color: :danger, class: "mr-2") %> Before: Flowbite
          </h3>

          <div class="space-y-3 text-sm">
            <div class="rounded border border-red-200 bg-red-50 p-3 dark:border-red-800 dark:bg-red-900/20">
              <div class="mb-1 font-semibold text-red-900 dark:text-red-100">External Dependency</div>
              <div class="text-red-800 dark:text-red-200">Required Flowbite + Popper.js libraries</div>
            </div>

            <div class="rounded border border-red-200 bg-red-50 p-3 dark:border-red-800 dark:bg-red-900/20">
              <div class="mb-1 font-semibold text-red-900 dark:text-red-100">JavaScript Positioning</div>
              <div class="text-red-800 dark:text-red-200">Complex JS-based positioning logic</div>
            </div>

            <div class="rounded border border-red-200 bg-red-50 p-3 dark:border-red-800 dark:bg-red-900/20">
              <div class="mb-1 font-semibold text-red-900 dark:text-red-100">Larger Bundle</div>
              <div class="text-red-800 dark:text-red-200">Additional JavaScript payload</div>
            </div>
          </div>
        </div>

        <!-- After: Custom JavaScript -->
        <div>
          <h3 class="mb-4 flex items-center text-lg font-semibold text-slate-900 dark:text-slate-100">
            <%= icon(:check_circle, color: :success, class: "mr-2") %> After: Custom JavaScript
          </h3>

          <div class="space-y-3 text-sm">
            <div class="rounded border border-green-200 bg-green-50 p-3 dark:border-green-800 dark:bg-green-900/20">
              <div class="mb-1 font-semibold text-green-900 dark:text-green-100">Zero External Dependencies</div>

              <div class="text-green-800 dark:text-green-200">
                Custom Stimulus controller with no positioning libraries
              </div>
            </div>

            <div class="rounded border border-green-200 bg-green-50 p-3 dark:border-green-800 dark:bg-green-900/20">
              <div class="mb-1 font-semibold text-green-900 dark:text-green-100">JavaScript Positioning</div>

              <div class="text-green-800 dark:text-green-200">
                Sophisticated viewport detection with automatic placement flipping
              </div>
            </div>

            <div class="rounded border border-green-200 bg-green-50 p-3 dark:border-green-800 dark:bg-green-900/20">
              <div class="mb-1 font-semibold text-green-900 dark:text-green-100">Smaller Bundle</div>
              <div class="text-green-800 dark:text-green-200">Reduced JavaScript footprint (no Popper.js)</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Resources -->
  <div>
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:books, color: :primary, class: "mr-3") %> Additional Resources
    </h2>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-3 flex items-center font-semibold text-slate-900 dark:text-slate-100">
          <%= icon(:link, color: :primary, class: "mr-2") %> getBoundingClientRect API
        </h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
          Learn about the DOM API used for precise element positioning calculations.
        </p>

        <a
          href="https://developer.mozilla.org/en-US/docs/Web/API/Element/getBoundingClientRect"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-blue-600 hover:underline dark:text-blue-400"
        >
          MDN: getBoundingClientRect() →
        </a>
      </div>

      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-3 flex items-center font-semibold text-slate-900 dark:text-slate-100">
          <%= icon(:lightbulb, color: :warning, class: "mr-2") %> Primer Design System
        </h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
          Explore GitHub's Primer design system for tooltip design inspiration and patterns.
        </p>

        <a
          href="https://primer.style/product/components/tooltip/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-blue-600 hover:underline dark:text-blue-400"
        >
          Primer Tooltip Component →
        </a>
      </div>

      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-3 flex items-center font-semibold text-slate-900 dark:text-slate-100">
          <%= icon(:code, color: :primary, class: "mr-2") %> Stimulus Framework
        </h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
          Learn about the Stimulus JavaScript framework used for the tooltip controller.
        </p>

        <a
          href="https://stimulus.hotwired.dev/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-blue-600 hover:underline dark:text-blue-400"
        >
          Stimulus Documentation →
        </a>
      </div>

      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-3 flex items-center font-semibold text-slate-900 dark:text-slate-100">
          <%= icon(:wheelchair, color: :success, class: "mr-2") %> ARIA Tooltip Pattern
        </h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
          W3C WAI-ARIA best practices for implementing accessible tooltip components.
        </p>

        <a
          href="https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-blue-600 hover:underline dark:text-blue-400"
        >
          WAI-ARIA: Tooltip Pattern →
        </a>
      </div>
    </div>
  </div>
</div>
