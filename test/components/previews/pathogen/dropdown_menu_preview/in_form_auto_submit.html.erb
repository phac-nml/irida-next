<div
  class="
    p-8 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900
    dark:to-slate-800 min-h-screen
  "
>
  <div class="mb-10 text-center">
    <h1 class="text-4xl font-bold text-slate-900 dark:text-slate-100 mb-4">
      <%= pathogen_icon(:keyboard, color: :primary, size: :xl, class: "inline mr-3") %>
      Dropdown Menu - Embedded In Form + Auto Submit
    </h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 max-w-3xl mx-auto">
      Radio items can dispatch a change event and then requestSubmit() the
      nearest form when auto_submit is enabled.
    </p>
  </div>

  <div
    class="
      bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-slate-200
      dark:border-slate-700 p-8
    "
  >
    <%= form_with url: "#", method: :get, class: "flex items-center justify-between gap-8" do %>
      <div class="space-y-2">
        <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100">Example</h2>
        <p class="text-slate-600 dark:text-slate-400">
          Selecting an option submits the form. Escape/outside click reverts
          the selection.
        </p>
      </div>

      <%= render(Pathogen::DropdownMenu.new(auto_submit: true)) do |menu| %>
        <% menu.with_trigger(aria_label: "Open sort menu", class: "button button-default") do %>
          <span class="inline-flex items-center gap-2">
            <%= pathogen_icon(:keyboard, size: :sm) %>
            <span>Sort</span>
          </span>
        <% end %>

        <% menu.with_radio_item(
          label: "Newest",
          name: "sort",
          value: "newest",
          checked: true,
        ) %>
        <% menu.with_radio_item(label: "Oldest", name: "sort", value: "oldest") %>
        <% menu.with_radio_item(label: "Name", name: "sort", value: "name") %>
      <% end %>
    <% end %>

    <div class="mt-8">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-2">Notes</h3>
      <ul class="list-disc list-inside text-slate-600 dark:text-slate-400 space-y-1">
        <li>Auto-submit uses
          <span class="font-mono">requestSubmit()</span>
          on the nearest form.</li>
        <li>Apps can also listen for
          <span class="font-mono">pathogen:dropdown-menu:change</span>
          and persist with Turbo/fetch.</li>
      </ul>
    </div>
  </div>
</div>
