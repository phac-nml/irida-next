<div class="min-h-screen bg-gradient-to-br from-purple-50 to-pink-100 p-8 dark:from-slate-900 dark:to-slate-800">
  <!-- Header -->
  <div class="mb-12 text-center">
    <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-slate-100">
      <%= icon(:squares_four, color: :primary, size: :xl, class: "inline mr-3") %> Icon Library Showcase
    </h1>

    <p class="mx-auto max-w-3xl text-lg text-slate-600 dark:text-slate-400">
      Comprehensive collection of available icons across different libraries and categories.
    </p>
  </div>

  <!-- Phosphor Icons (Default) -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:circle, color: :primary, class: "mr-3") %> Phosphor Icons (Default Library)
    </h2>

    <p class="mb-6 text-slate-600 dark:text-slate-400">The default icon library with a comprehensive set of icons.</p>

    <!-- Common Icons -->
    <div class="mb-8">
      <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-100">Common Interface Icons</h3>

      <div class="grid grid-cols-4 gap-4 md:grid-cols-6 lg:grid-cols-8 xl:grid-cols-12">
        <% [
          :house_line, :user, :users, :gear_six, :gear_six, :bell, :envelope,
          :magnifying_glass, :plus, :minus, :x, :check,
          :heart, :star, :bookmark, :flag, :calendar, :clock,
          :pencil, :trash, :trash, :folder_open, :file,
          :download, :upload, :share, :link, :eye, :eye_slash,
          :arrow_up, :arrow_down, :arrow_left, :arrow_right, :caret_up, :caret_down,
          :question, :info, :warning, :check_circle, :x_circle
        ].each do |icon| %>
          <div
            class="
              rounded-lg border border-slate-200 bg-white p-3 text-center shadow-sm dark:border-slate-700
              dark:bg-slate-800
            "
          >
            <div class="mb-2 flex h-10 items-center justify-center"><%= icon(icon, color: :default, size: :md) %></div>
            <p class="text-xs break-words text-slate-600 dark:text-slate-400"><%= icon %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- App-Specific Icons -->
    <div class="mb-8">
      <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-100">Application Icons</h3>

      <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-6">
        <% [
          { icon: :test_tube, name: "Samples", color: :primary },
          { icon: Project.icon, name: "Projects", color: :success },
          { icon: :squares_four, name: "Groups", color: :warning },
          { icon: :terminal_window, name: "Workflows", color: :danger },
          { icon: :export, name: "Data Exports", color: :subdued },
          { icon: :ticket, name: "Tokens", color: :primary }
        ].each do |item| %>
          <div
            class="
              rounded-lg border border-slate-200 bg-white p-4 text-center shadow-sm dark:border-slate-700
              dark:bg-slate-800
            "
          >
            <div class="mb-3 flex h-12 items-center justify-center">
              <%= icon(item[:icon], color: item[:color], size: :lg) %>
            </div>

            <h4 class="mb-1 font-medium text-slate-900 dark:text-slate-100"><%= item[:name] %></h4>
            <code class="text-xs text-slate-500 dark:text-slate-400"><%= item[:icon] %></code>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Heroicons -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:beaker, library: :heroicons, color: :primary, class: "mr-3") %> Heroicons Library
    </h2>

    <p class="mb-6 text-slate-600 dark:text-slate-400">
      Beautiful hand-crafted SVG icons by the makers of Tailwind CSS.
    </p>

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-100">Heroicons Examples</h3>

      <div class="mb-6 grid grid-cols-4 gap-4 md:grid-cols-6 lg:grid-cols-8">
        <% [:beaker, :academic_cap, :adjustments_horizontal, :archive_box, :arrow_path, :bell, :book_open].each do |icon| %>
          <div class="text-center">
            <div class="mb-2 flex h-10 items-center justify-center">
              <%= icon(icon, library: :heroicons, color: :primary, size: :md) %>
            </div>

            <p class="text-xs text-slate-600 dark:text-slate-400"><%= icon %></p>
          </div>
        <% end %>
      </div>

      <code class="block rounded bg-slate-100 p-3 text-sm text-slate-700 dark:bg-slate-700 dark:text-slate-300">
        &lt;%= icon(:beaker, library: :heroicons) %&gt;
      </code>
    </div>
  </div>

  <!-- Icon Variants -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:palette, color: :primary, class: "mr-3") %> Icon Variants
    </h2>

    <p class="mb-6 text-slate-600 dark:text-slate-400">Different visual styles for the same icon concept.</p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <!-- Phosphor Variants -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Phosphor Variants</h3>

        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-slate-700 dark:text-slate-300">Regular (default)</span>

            <div class="flex items-center gap-3">
              <%= icon(:heart, size: :lg, color: :danger) %>
              <%= icon(:star, size: :lg, color: :warning) %>
              <%= icon(:bookmark, size: :lg, color: :primary) %>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-slate-700 dark:text-slate-300">Fill</span>

            <div class="flex items-center gap-3">
              <%= icon(:heart, variant: :fill, size: :lg, color: :danger) %>
              <%= icon(:star, variant: :fill, size: :lg, color: :warning) %>
              <%= icon(:bookmark, variant: :fill, size: :lg, color: :primary) %>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-slate-700 dark:text-slate-300">Duotone</span>

            <div class="flex items-center gap-3">
              <%= icon(:heart, variant: :duotone, size: :lg, color: :danger) %>
              <%= icon(:star, variant: :duotone, size: :lg, color: :warning) %>
              <%= icon(:bookmark, variant: :duotone, size: :lg, color: :primary) %>
            </div>
          </div>
        </div>
      </div>

      <!-- Heroicons Variants -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Heroicons Variants</h3>

        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-slate-700 dark:text-slate-300">Outline (default)</span>

            <div class="flex items-center gap-3">
              <%= icon(:heart, library: :heroicons, size: :lg, color: :danger) %>
              <%= icon(:star, library: :heroicons, size: :lg, color: :warning) %>
              <%= icon(:bookmark, library: :heroicons, size: :lg, color: :primary) %>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-slate-700 dark:text-slate-300">Solid</span>

            <div class="flex items-center gap-3">
              <%= icon(:heart, library: :heroicons, variant: :solid, size: :lg, color: :danger) %>
              <%= icon(:star, library: :heroicons, variant: :solid, size: :lg, color: :warning) %>
              <%= icon(:bookmark, library: :heroicons, variant: :solid, size: :lg, color: :primary) %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Variant Examples -->
    <div class="mt-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Using Variants</h3>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div>
          <h4 class="mb-3 font-medium text-slate-900 dark:text-slate-100">Phosphor Variants</h4>

          <div class="space-y-2 text-sm">
            <code class="block rounded bg-slate-100 p-2 text-slate-700 dark:bg-slate-700 dark:text-slate-300">
              Icon.new(:heart, variant: :fill)
            </code>

            <code class="block rounded bg-slate-100 p-2 text-slate-700 dark:bg-slate-700 dark:text-slate-300">
              Icon.new(:star, variant: :duotone)
            </code>
          </div>
        </div>

        <div>
          <h4 class="mb-3 font-medium text-slate-900 dark:text-slate-100">Heroicons Variants</h4>

          <div class="space-y-2 text-sm">
            <code class="block rounded bg-slate-100 p-2 text-slate-700 dark:bg-slate-700 dark:text-slate-300">
              Icon.new(:heart, library: :heroicons, variant: :solid)
            </code>

            <code class="block rounded bg-slate-100 p-2 text-slate-700 dark:bg-slate-700 dark:text-slate-300">
              Icon.new(:star, library: :heroicons, variant: :outline)
            </code>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Best Practices -->
  <div>
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:lightbulb, color: :primary, class: "mr-3") %> Best Practices
    </h2>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <!-- Do's -->
      <div class="rounded-xl border border-green-200 bg-green-50 p-6 dark:border-green-800 dark:bg-green-900/20">
        <h3 class="mb-4 flex items-center font-semibold text-green-800 dark:text-green-200">
          <%= icon(:check_circle, color: :success, size: :sm, class: "mr-2") %> Do's
        </h3>

        <ul class="space-y-3 text-sm text-green-700 dark:text-green-300">
          <li class="flex items-start">
            <span class="mr-2">•</span> Use semantic icons with aria-labels for meaningful content
          </li>

          <li class="flex items-start">
            <span class="mr-2">•</span> Choose appropriate sizes for context (sm for inline, lg for features)
          </li>

          <li class="flex items-start">
            <span class="mr-2">•</span> Use color variants that match your UI state (success, danger, etc.)
          </li>

          <li class="flex items-start"><span class="mr-2">•</span> Leverage factory methods for common patterns</li>

          <li class="flex items-start">
            <span class="mr-2">•</span> Test with screen readers when using semantic icons
          </li>
        </ul>
      </div>

      <!-- Don'ts -->
      <div class="rounded-xl border border-red-200 bg-red-50 p-6 dark:border-red-800 dark:bg-red-900/20">
        <h3 class="mb-4 flex items-center font-semibold text-red-800 dark:text-red-200">
          <%= icon(:x_circle, color: :danger, size: :sm, class: "mr-2") %> Don'ts
        </h3>

        <ul class="space-y-3 text-sm text-red-700 dark:text-red-300">
          <li class="flex items-start">
            <span class="mr-2">•</span> Don't use semantic icons without proper aria-labels
          </li>

          <li class="flex items-start">
            <span class="mr-2">•</span> Don't mix icon libraries unnecessarily in the same interface
          </li>

          <li class="flex items-start">
            <span class="mr-2">•</span> Don't use colors that don't have semantic meaning
          </li>

          <li class="flex items-start"><span class="mr-2">•</span> Don't ignore the console warnings in development</li>
          <li class="flex items-start"><span class="mr-2">•</span> Don't use overly large icons in dense interfaces</li>
        </ul>
      </div>
    </div>

    <!-- Quick Reference -->
    <div class="mt-6 rounded-xl border border-slate-200 bg-slate-100 p-6 dark:border-slate-700 dark:bg-slate-800">
      <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Quick Reference</h3>

      <div class="grid grid-cols-1 gap-4 text-sm md:grid-cols-2 lg:grid-cols-4">
        <div>
          <h4 class="mb-2 font-medium text-slate-900 dark:text-slate-100">Colors</h4>

          <ul class="space-y-1 text-slate-600 dark:text-slate-400">
            <li>:default</li>
            <li>:primary</li>
            <li>:success</li>
            <li>:warning</li>
            <li>:danger</li>
            <li>:subdued</li>
          </ul>
        </div>

        <div>
          <h4 class="mb-2 font-medium text-slate-900 dark:text-slate-100">Sizes</h4>

          <ul class="space-y-1 text-slate-600 dark:text-slate-400">
            <li>:sm (16px)</li>
            <li>:md (24px)</li>
            <li>:lg (32px)</li>
            <li>:xl (40px)</li>
          </ul>
        </div>

        <div>
          <h4 class="mb-2 font-medium text-slate-900 dark:text-slate-100">Libraries</h4>

          <ul class="space-y-1 text-slate-600 dark:text-slate-400">
            <li>:phosphor (default)</li>
            <li>:heroicons</li>
          </ul>
        </div>

        <div>
          <h4 class="mb-2 font-medium text-slate-900 dark:text-slate-100">Accessibility</h4>

          <ul class="space-y-1 text-slate-600 dark:text-slate-400">
            <li>semantic: true</li>
            <li>aria-label: "text"</li>
            <li>aria-hidden: false</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
