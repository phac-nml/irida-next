<div class="min-h-screen bg-gradient-to-br from-emerald-50 to-teal-100 p-8 dark:from-slate-900 dark:to-slate-800">
  <!-- Header -->
  <div class="mb-12 text-center">
    <h1 class="mb-4 text-4xl font-bold text-slate-900 dark:text-slate-100">
      <%= icon(:hammer, color: :primary, size: :xl, class: "inline mr-3") %> Factory Methods & Enhanced Features
    </h1>

    <p class="mx-auto max-w-3xl text-lg text-slate-600 dark:text-slate-400">
      Convenient shortcuts and powerful new features for better developer experience.
    </p>
  </div>

  <!-- Color Factory Methods -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:paint_brush, color: :primary, class: "mr-3") %> Color Factory Methods
    </h2>

    <p class="mb-6 text-slate-600 dark:text-slate-400">Quick shortcuts for common color patterns.</p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% [
        { method: "success", icon: :check_circle, color: :success, desc: "Perfect for confirmations and positive actions" },
        { method: "danger", icon: :warning, color: :danger, desc: "Ideal for errors, warnings, and destructive actions" },
        { method: "warning", icon: :warning_circle, color: :warning, desc: "Great for caution messages and alerts" },
        { method: "primary", icon: :star, color: :primary, desc: "Use for brand elements and CTAs" },
        { method: "subdued", icon: :info, color: :subdued, desc: "Perfect for secondary information" }
      ].each do |item| %>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
          <div class="mb-4 flex h-16 items-center justify-center rounded-lg bg-slate-50 dark:bg-slate-700">
            <%= icon(item[:icon], color: item[:color], size: :lg) %>
          </div>

          <h3 class="mb-2 font-semibold text-slate-900 dark:text-slate-100">
            Icon.new() with color: :<%= item[:method] %>
          </h3>

          <p class="mb-3 text-sm text-slate-600 dark:text-slate-400"><%= item[:desc] %></p>

          <code class="block rounded bg-slate-100 px-2 py-1 text-xs text-slate-700 dark:bg-slate-700 dark:text-slate-300">
            icon(<%= item[:icon] %>, color: :<%= item[:method] %>)
          </code>
        </div>
      <% end %>
    </div>

    <!-- Factory Methods in Action -->
    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Factory Methods in Action</h3>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div>
          <h4 class="mb-3 font-medium text-slate-900 dark:text-slate-100">Status Messages</h4>

          <div class="space-y-3">
            <div class="flex items-center gap-3 rounded-lg bg-green-50 p-3 dark:bg-green-900/20">
              <%= icon(:check_circle, color: :success) %>
              <span class="text-green-800 dark:text-green-200">Payment processed successfully</span>
            </div>

            <div class="flex items-center gap-3 rounded-lg bg-yellow-50 p-3 dark:bg-yellow-900/20">
              <%= icon(:warning, color: :warning) %>
              <span class="text-yellow-800 dark:text-yellow-200">Account verification pending</span>
            </div>

            <div class="flex items-center gap-3 rounded-lg bg-red-50 p-3 dark:bg-red-900/20">
              <%= icon(:x_circle, color: :danger) %>
              <span class="text-red-800 dark:text-red-200">Unable to connect to server</span>
            </div>
          </div>
        </div>

        <div>
          <h4 class="mb-3 font-medium text-slate-900 dark:text-slate-100">Interface Elements</h4>

          <div class="space-y-3">
            <button class="flex w-full items-center gap-2 rounded-lg bg-primary-600 px-4 py-2 text-white">
              <%= icon(:plus, color: :primary, size: :sm, class: "text-white") %> Create New Project
            </button>

            <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-400">
              <%= icon(:clock, color: :subdued) %>
              <span>Last updated 5 minutes ago</span>
            </div>

            <div class="flex items-center justify-between rounded-lg border border-slate-200 p-3 dark:border-slate-700">
              <span class="text-slate-900 dark:text-slate-100">Delete Account</span>
              <%= icon(:trash, color: :danger, size: :sm) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Size Factory Methods -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:arrows_out, color: :primary, class: "mr-3") %> Size Factory Methods
    </h2>

    <p class="mb-6 text-slate-600 dark:text-slate-400">Quick shortcuts for common size patterns.</p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      <div
        class="
          rounded-xl border border-slate-200 bg-white p-6 text-center shadow-sm dark:border-slate-700
          dark:bg-slate-800
        "
      >
        <div class="mb-4 flex h-16 items-center justify-center rounded-lg bg-slate-50 dark:bg-slate-700">
          <%= icon(:heart, color: :danger, size: :sm) %>
        </div>

        <h3 class="mb-2 font-semibold text-slate-900 dark:text-slate-100">Icon.new() with size: :sm</h3>

        <p class="mb-3 text-sm text-slate-600 dark:text-slate-400">Perfect for inline use in text</p>

        <code class="rounded bg-slate-100 px-2 py-1 text-xs text-slate-700 dark:bg-slate-700 dark:text-slate-300">
          Icon.new(:heart, size: :sm)
        </code>
      </div>

      <div
        class="
          rounded-xl border border-slate-200 bg-white p-6 text-center shadow-sm dark:border-slate-700
          dark:bg-slate-800
        "
      >
        <div class="mb-4 flex h-16 items-center justify-center rounded-lg bg-slate-50 dark:bg-slate-700">
          <%= icon(:star, color: :primary, size: :lg) %>
        </div>

        <h3 class="mb-2 font-semibold text-slate-900 dark:text-slate-100">Icon.new() with size: :lg</h3>

        <p class="mb-3 text-sm text-slate-600 dark:text-slate-400">Great for feature highlights</p>

        <code class="rounded bg-slate-100 px-2 py-1 text-xs text-slate-700 dark:bg-slate-700 dark:text-slate-300">
          Icon.new(:star, size: :lg)
        </code>
      </div>

      <div
        class="
          rounded-xl border border-slate-200 bg-white p-6 text-center shadow-sm dark:border-slate-700
          dark:bg-slate-800
        "
      >
        <div class="mb-4 flex h-16 items-center justify-center rounded-lg bg-slate-50 dark:bg-slate-700">
          <%= icon(:rocket_launch, color: :success, size: :xl) %>
        </div>

        <h3 class="mb-2 font-semibold text-slate-900 dark:text-slate-100">Icon.new() with size: :xl</h3>

        <p class="mb-3 text-sm text-slate-600 dark:text-slate-400">Ideal for hero sections</p>

        <code class="rounded bg-slate-100 px-2 py-1 text-xs text-slate-700 dark:bg-slate-700 dark:text-slate-300">
          Icon.new(:rocket, size: :xl)
        </code>
      </div>
    </div>
  </div>

  <!-- Accessibility Features -->
  <div class="mb-12">
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:eye, color: :primary, class: "mr-3") %> Accessibility Features
    </h2>

    <p class="mb-6 text-slate-600 dark:text-slate-400">
      Built-in accessibility with semantic and decorative icon handling.
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <!-- Semantic Icons -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 flex items-center font-semibold text-slate-900 dark:text-slate-100">
          <%= icon(:info, color: :primary, "aria-label": "Information", size: :sm, class: "mr-2") %> Semantic Icons
        </h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
          Icons that convey meaning and should be announced by screen readers.
        </p>

        <div class="space-y-4">
          <div class="rounded-lg border-l-4 border-blue-400 bg-blue-50 p-3 dark:bg-blue-900/20">
            <%= icon(:info, color: :primary, "aria-label": "Important information", class: "float-left mr-2 mt-0.5") %>

            <p class="text-sm text-blue-800 dark:text-blue-200">
              This icon conveys important information and includes an aria-label for screen readers.
            </p>
          </div>

          <code class="block rounded bg-slate-100 p-3 text-xs text-slate-700 dark:bg-slate-700 dark:text-slate-300">
            &lt;%= icon(:info, "aria-label": "Important information") %&gt;
          </code>

          <div class="text-xs text-slate-500 dark:text-slate-400">
            <strong>Features:</strong> aria-hidden="false", role="img", requires aria-label
          </div>
        </div>
      </div>

      <!-- Decorative Icons -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 flex items-center font-semibold text-slate-900 dark:text-slate-100">
          <%= icon(:sparkle, color: :primary, size: :sm, class: "mr-2", "aria-hidden": true) %> Decorative Icons
        </h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
          Icons that are purely visual and should be hidden from screen readers.
        </p>

        <div class="space-y-4">
          <div class="rounded-lg bg-slate-50 p-3 dark:bg-slate-700">
            <h4 class="flex items-center font-medium text-slate-900 dark:text-slate-100">
              <%= icon(:sparkle, color: :primary, size: :sm, class: "mr-2", "aria-hidden": true) %> Beautiful Design
            </h4>

            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              The sparkle icon is decorative and enhances the visual appeal.
            </p>
          </div>

          <code class="block rounded bg-slate-100 p-3 text-xs text-slate-700 dark:bg-slate-700 dark:text-slate-300">
            &lt;%= icon(:sparkle, "aria-hidden": true) %&gt;
          </code>

          <div class="text-xs text-slate-500 dark:text-slate-400">
            <strong>Features:</strong> aria-hidden="true" (hidden from screen readers)
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Error Handling & Fallbacks -->
  <div>
    <h2 class="mb-6 flex items-center text-2xl font-semibold text-slate-900 dark:text-slate-100">
      <%= icon(:shield_check, color: :primary, class: "mr-3") %> Error Handling & Fallbacks
    </h2>

    <p class="mb-6 text-slate-600 dark:text-slate-400">
      Robust error handling with helpful developer feedback and graceful fallbacks.
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <!-- Development Mode -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Development Mode</h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
          Invalid icons show helpful error messages with suggestions.
        </p>

        <div class="space-y-3">
          <div class="rounded-lg border border-red-200 bg-red-50 p-3 dark:border-red-800 dark:bg-red-900/20">
            <span class="rounded border border-red-300 bg-red-50 px-2 py-1 font-mono text-xs text-red-500">
              ⚠️ Icon 'invalid-icon-name' not found (Suggestions: check, check-circle, check-badge)
            </span>
          </div>

          <code class="block rounded bg-slate-100 p-3 text-xs text-slate-700 dark:bg-slate-700 dark:text-slate-300">
            &lt;%= icon(:invalid_icon_name) %&gt;
          </code>
        </div>

        <div class="mt-4 text-xs text-slate-500 dark:text-slate-400">
          <strong>Features:</strong> Smart suggestions, debug CSS classes, detailed error info
        </div>
      </div>

      <!-- Production Mode -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Production Mode</h3>

        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">Graceful fallbacks prevent layout breakage.</p>

        <div class="space-y-3">
          <div class="rounded-lg bg-slate-50 p-3 dark:bg-slate-700">
            <div class="flex items-center gap-3">
              <%= icon(:question, color: :subdued) %>
              <span class="text-slate-600 dark:text-slate-400">Fallback icon when primary fails</span>
            </div>
          </div>

          <div class="text-sm text-slate-600 dark:text-slate-400">
            If no fallback works, renders nothing (graceful degradation)
          </div>
        </div>

        <div class="mt-4 text-xs text-slate-500 dark:text-slate-400">
          <strong>Features:</strong> Silent failures, fallback icons, layout preservation
        </div>
      </div>
    </div>

    <!-- Parameter Validation -->
    <div class="mt-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
      <h3 class="mb-4 font-semibold text-slate-900 dark:text-slate-100">Parameter Validation</h3>

      <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
        Helpful warnings for invalid parameters with automatic fallbacks.
      </p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div>
          <h4 class="mb-2 font-medium text-slate-900 dark:text-slate-100">Invalid Color</h4>

          <div
            class="
              mb-2 rounded bg-orange-50 p-2 font-mono text-xs text-orange-600 dark:bg-orange-900/20
              dark:text-orange-400
            "
          >
            [Pathogen::Icon] Invalid color 'purple', falling back to :default. Valid colors: default, primary, success,
            warning, danger, subdued
          </div>

          <code class="block rounded bg-slate-100 p-2 text-xs dark:bg-slate-700">
            Icon.new(:star, color: :purple)
          </code>
        </div>

        <div>
          <h4 class="mb-2 font-medium text-slate-900 dark:text-slate-100">Invalid Size</h4>

          <div
            class="
              mb-2 rounded bg-orange-50 p-2 font-mono text-xs text-orange-600 dark:bg-orange-900/20
              dark:text-orange-400
            "
          >
            [Pathogen::Icon] Invalid size 'huge', falling back to :md. Valid sizes: sm, md, lg, xl
          </div>

          <code class="block rounded bg-slate-100 p-2 text-xs dark:bg-slate-700"> Icon.new(:star, size: :huge) </code>
        </div>
      </div>
    </div>
  </div>
</div>
